# ==========================================================================
#  ERPSystem — VPS deployment configuration
#  انسخ هذا الملف إلى:  deploy/.env   ثم عدّل القيم
#      cp deploy/.env.example deploy/.env
#  ثم:  chmod 600 deploy/.env   (يحتوي كلمات مرور — احمِه)
# ==========================================================================

# --- الدومين / Domain ---
DOMAIN="alamal-ab.org"
WWW_DOMAIN="www.alamal-ab.org"          # اتركه فارغاً "" إن لم يكن لديك سجل www
LETSENCRYPT_EMAIL="sezarooo700@gmail.com"

# هل يدير السكربت شهادة HTTPS؟
#   yes = يصدر/يجدّد الشهادة عبر certbot تلقائياً
#   no  = الشهادة مثبتة مسبقاً — تخطَّ إصدار الشهادة (لا تلمس إعداد SSL الحالي)
MANAGE_SSL="no"

# --- مستودع الشيفرة / Git repository ---
REPO_URL="https://github.com/homsi777/ERPSystem.git"
REPO_BRANCH="main"
# إن كان المستودع خاصاً استخدم رابطاً يتضمن Personal Access Token، مثال:
# REPO_URL="https://<USERNAME>:<TOKEN>@github.com/homsi777/ERPSystem.git"

# --- قاعدة البيانات / PostgreSQL ---
DB_NAME="erp_pro"
DB_APP_USER="erp_app"                     # مستخدم التطبيق (وليس postgres الجذر)
DB_APP_PASSWORD="12345678"                # كلمة مرور مؤقتة للتجارب — غيّرها لاحقاً
DB_PORT="5432"

# اسمح باتصال تطبيق سطح المكتب عن بُعد بقاعدة البيانات؟ (yes/no)
# إن كانت yes سيُفتح المنفذ 5432. يُفضّل حصره بعناوين IP محددة (انظر أدناه).
ENABLE_REMOTE_DB="yes"
# قائمة IP/نطاقات مسموح لها بالاتصال بقاعدة البيانات عن بُعد (مفصولة بمسافة).
# اتركها "0.0.0.0/0" للسماح للجميع (غير مُوصى به) أو ضع IP مكتبك مثل "203.0.113.10/32".
DB_REMOTE_ALLOWED_CIDRS="0.0.0.0/0"

# --- أمان API / API security ---
# مفتاح توقيع JWT — اتركه فارغاً ليولّده السكربت تلقائياً ويحفظه.
JWT_SECRET=""

# المنفذ الداخلي للمشروع (Kestrel/API) خلف Nginx
API_PORT="4066"

# المنفذ الخارجي الذي يستمع عليه Nginx للدومين (الجهة الخارجية/الطبقة الأمامية توجّه alamal-ab.org إليه)
# اجعله 80 إذا كان Nginx هو الواجهة المباشرة على الإنترنت.
WEB_LISTEN_PORT="3000"

# --- خيارات البناء / Build options ---
# ابنِ web-client على الخادم؟ (yes/no) — يتطلب Node.js
BUILD_WEB_CLIENT="yes"
# مستخدم النظام الذي سيشغّل الـ API service
SERVICE_USER="erpapi"
