<Window x:Class="ERPSystem.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:auth="clr-namespace:ERPSystem.Views.Auth"
        Title="الأمل.AB — تسجيل الدخول"
        Width="1080" Height="680"
        MinWidth="920" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI, Tahoma, Arial"
        WindowStyle="SingleBorderWindow"
        Background="#0B1020">

    <Window.Resources>
        <LinearGradientBrush x:Key="LoginBgBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F0C29" Offset="0"/>
            <GradientStop Color="#302B63" Offset="0.55"/>
            <GradientStop Color="#24243E" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="LoginButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="LoginInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#141B33"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#2A3558"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#C4B5FD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#667EEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#141B33"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#2A3558"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#667EEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Background="{StaticResource LoginButtonBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="LoginContent" Background="{StaticResource LoginBgBrush}">
        <!-- Glow orbs -->
        <Ellipse Width="320" Height="320" HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-80,-60,0" Opacity="0.35" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#667EEA" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="40"/>
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="260" Height="260" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-40,0,0,-40" Opacity="0.28" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#764BA2" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="36"/>
            </Ellipse.Effect>
        </Ellipse>

        <Grid Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <!-- Hero (RTL start / right) -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="24,0,32,0">
                <TextBlock Text="أدر عملك بذكاء ⚡" FontSize="34" FontWeight="Bold"
                           Foreground="White" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock Text="نظام ERP متكامل — تجارة أقمشة الجينز"
                           FontSize="15" Foreground="#CBD5E1" Margin="0,0,0,28"/>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="42" Height="42" CornerRadius="10" Background="#312E81" Margin="0,0,12,0">
                            <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="مبيعات ومشتريات" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="فواتير، اعتماد، وتتبع كامل" FontSize="12" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="42" Height="42" CornerRadius="10" Background="#064E3B" Margin="0,0,12,0">
                            <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="محاسبة وتقارير" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="قيود، صناديق، وأرصدة فورية" FontSize="12" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="42" Height="42" CornerRadius="10" Background="#831843" Margin="0,0,12,0">
                            <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="استيراد الصين والمخزون" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="حاويات، تفصيل، ومستودعات" FontSize="12" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="42" Height="42" CornerRadius="10" Background="#155E75" Margin="0,0,12,0">
                            <TextBlock Text="☁" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="سحابي متكامل" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="متصفح وسطح مكتب على قاعدة واحدة" FontSize="12" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Login card -->
            <Border Grid.Column="1" CornerRadius="24" Padding="32,28"
                    Background="#12182B" BorderBrush="#2A3558" BorderThickness="1"
                    VerticalAlignment="Center" MaxWidth="420">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                        <Border Width="56" Height="56" CornerRadius="14" Background="#1E293B" Margin="0,0,14,0">
                            <Image x:Name="ImgLogo" Stretch="Uniform" Margin="6"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="الأمل.AB" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="تجارة أقمشة الجينز — جملة" FontSize="12" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="مرحباً بعودتك 👋" FontSize="24" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,6"/>
                    <TextBlock Text="سجّل الدخول للمتابعة إلى لوحة التحكم"
                               FontSize="13" Foreground="#94A3B8" Margin="0,0,0,22"/>

                    <TextBlock Text="اسم المستخدم" Foreground="#CBD5E1" FontSize="13" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtUsername" Style="{StaticResource LoginInputStyle}" Margin="0,0,0,14"/>

                    <TextBlock Text="كلمة المرور" Foreground="#CBD5E1" FontSize="13" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="TxtPassword" Style="{StaticResource LoginPasswordStyle}" Margin="0,0,0,8"
                                 KeyDown="TxtPassword_OnKeyDown"/>

                    <TextBlock x:Name="TxtError" Foreground="#FCA5A5" FontSize="12"
                               TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>

                    <Button x:Name="BtnLogin" Content="تسجيل الدخول ←" Style="{StaticResource LoginButtonStyle}"
                            Margin="0,18,0,0" Click="BtnLogin_OnClick"/>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>

        <auth:LoginSecuritySplashControl x:Name="SplashOverlay" Visibility="Collapsed"/>
    </Grid>
</Window>
