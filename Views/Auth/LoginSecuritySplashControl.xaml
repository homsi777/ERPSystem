<UserControl x:Class="ERPSystem.Views.Auth.LoginSecuritySplashControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             FontFamily="Segoe UI, Tahoma, Arial"
             Background="#0B1020">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="SplashBgBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F0C29" Offset="0"/>
            <GradientStop Color="#302B63" Offset="0.55"/>
            <GradientStop Color="#24243E" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid Background="{StaticResource SplashBgBrush}">
        <Ellipse Width="320" Height="320" HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-80,-60,0" Opacity="0.35" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#667EEA" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="40"/>
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="260" Height="260" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-40,0,0,-40" Opacity="0.28" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#764BA2" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="36"/>
            </Ellipse.Effect>
        </Ellipse>

        <Border MaxWidth="520" Padding="32,28" CornerRadius="24"
                Background="#12182B" BorderBrush="#2A3558" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
            </Border.Effect>

            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="64" Height="64" CornerRadius="14" Background="#1E293B" Margin="0,0,14,0">
                        <Image x:Name="ImgLogo" Stretch="Uniform" Margin="6"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="الأمل.AB" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="نظام ERP آمن — تجارة أقمشة الجينز" FontSize="12" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="جاري تجهيز بيئتك الآمنة" FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,6"/>
                <TextBlock Text="يرجى الانتظار لحظات قبل الدخول إلى لوحة التحكم"
                           FontSize="13" Foreground="#94A3B8" Margin="0,0,0,18"/>

                <ItemsControl x:Name="StepsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="8"
                                        Background="#1E293B" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Text}" FontSize="13"
                                           Foreground="{Binding ForegroundBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           TextWrapping="Wrap"/>
                                <Ellipse Grid.Column="2" Width="8" Height="8" Fill="#667EEA"
                                         VerticalAlignment="Center" Visibility="{Binding PulseVisibility}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="6" CornerRadius="3" Background="#1E293B" Margin="0,16,0,0">
                    <Border x:Name="ProgressFill" Height="6" CornerRadius="3" HorizontalAlignment="Right"
                            Background="#667EEA" Width="40"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
