<Window x:Class="ERPSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:ERPSystem.Shell"
        xmlns:workspace="clr-namespace:ERPSystem.Controls.Workspace"
        Title="الأمل.AB — تجارة أفخر أنواع أقمشة الجينز | استيراد من المصنع إلى منتجك"
        Icon="pack://siteoforigin:,,,/Assets/Brand/app-icon.ico"
        MinWidth="1024" MinHeight="660"
        Width="1440" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBgBrush}"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI, Tahoma, Arial">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="84"/>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <shell:TopContextBar Grid.Row="0" x:Name="TopBar"
                             SettingsRequested="TopBar_SettingsRequested"/>

        <shell:TopNavBar Grid.Row="1" x:Name="NavBar"
                         NavigationRequested="NavBar_NavigationRequested"/>

        <Grid Grid.Row="2">
            <ContentControl x:Name="WorkspaceHost"/>
            <workspace:WorkspaceLayerControl/>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="8" Height="8" CornerRadius="4"
                            Background="{StaticResource WarningBrush}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtStatusMessage" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="12,2"/>
                    <TextBlock x:Name="TxtDbStatus" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="12,2"/>
                    <TextBlock x:Name="TxtNavBreadcrumb" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="TxtVersionInfo"
                           Text="الأمل.AB v2.0 — تجارة أقمشة الجينز جملة"
                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
