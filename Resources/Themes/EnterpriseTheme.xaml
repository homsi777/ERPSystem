<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  ENTERPRISE COLOR SYSTEM                           -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- Primary Brand Colors -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryDarkColor">#1D4ED8</Color>
    <Color x:Key="PrimaryLightColor">#EFF6FF</Color>
    <Color x:Key="PrimaryVeryLightColor">#DBEAFE</Color>

    <!-- Sidebar Colors -->
    <Color x:Key="SidebarBgColor">#0F172A</Color>
    <Color x:Key="SidebarSectionBgColor">#1E293B</Color>
    <Color x:Key="SidebarHoverColor">#1E293B</Color>
    <Color x:Key="SidebarActiveColor">#2563EB</Color>
    <Color x:Key="SidebarActiveBgColor">#1E3A8A</Color>
    <Color x:Key="SidebarTextColor">#94A3B8</Color>
    <Color x:Key="SidebarActiveTextColor">#FFFFFF</Color>
    <Color x:Key="SidebarHeaderTextColor">#475569</Color>
    <Color x:Key="SidebarBorderColor">#1E293B</Color>
    <Color x:Key="SidebarLogoAreaColor">#020617</Color>

    <!-- App Surface Colors -->
    <Color x:Key="AppBgColor">#F1F5F9</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#F8FAFC</Color>

    <!-- Top Bar -->
    <Color x:Key="TopBarBgColor">#FFFFFF</Color>
    <Color x:Key="TopBarBorderColor">#E2E8F0</Color>

    <!-- Main horizontal nav (mockup navy) -->
    <Color x:Key="NavBarBgColor">#1A2B4B</Color>
    <Color x:Key="NavBarHoverColor">#243656</Color>
    <Color x:Key="NavBarActiveColor">#2D4268</Color>
    <Color x:Key="NavBarTextColor">#94A3B8</Color>
    <Color x:Key="NavBarActiveTextColor">#FFFFFF</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#1E293B</Color>
    <Color x:Key="TextSecondaryColor">#64748B</Color>
    <Color x:Key="TextMutedColor">#94A3B8</Color>
    <Color x:Key="TextInverseColor">#FFFFFF</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#E2E8F0</Color>
    <Color x:Key="BorderLightColor">#F1F5F9</Color>
    <Color x:Key="BorderFocusColor">#2563EB</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="SuccessBgColor">#ECFDF5</Color>
    <Color x:Key="SuccessBorderColor">#A7F3D0</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningBgColor">#FFFBEB</Color>
    <Color x:Key="WarningBorderColor">#FDE68A</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="DangerBgColor">#FEF2F2</Color>
    <Color x:Key="DangerBorderColor">#FECACA</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="InfoBgColor">#EFF6FF</Color>
    <Color x:Key="InfoBorderColor">#BFDBFE</Color>

    <!-- Metric Card Accent Colors -->
    <Color x:Key="AccentSalesColor">#2563EB</Color>
    <Color x:Key="AccentOrdersColor">#7C3AED</Color>
    <Color x:Key="AccentInventoryColor">#059669</Color>
    <Color x:Key="AccentReceivableColor">#D97706</Color>
    <Color x:Key="AccentPayableColor">#DC2626</Color>
    <Color x:Key="AccentCustomersColor">#0891B2</Color>

    <!-- Accent light backgrounds (semantic, not decorative) -->
    <Color x:Key="AccentOrdersLightColor">#EDE9FE</Color>
    <Color x:Key="AccentInventoryLightColor">#ECFDF5</Color>
    <Color x:Key="AccentReceivableLightColor">#FFFBEB</Color>
    <Color x:Key="AccentPayableLightColor">#FEF2F2</Color>
    <Color x:Key="AccentCustomersLightColor">#ECFEFF</Color>
    <Color x:Key="ChartBarLightColor">#BFDBFE</Color>
    <Color x:Key="ChartBarMidColor">#93C5FD</Color>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  BRUSHES                                           -->
    <!-- ═══════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimaryVeryLightBrush" Color="{StaticResource PrimaryVeryLightColor}"/>

    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="SidebarSectionBgBrush" Color="{StaticResource SidebarSectionBgColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBgBrush" Color="{StaticResource SidebarActiveBgColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="{StaticResource SidebarActiveTextColor}"/>
    <SolidColorBrush x:Key="SidebarHeaderTextBrush" Color="{StaticResource SidebarHeaderTextColor}"/>
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="{StaticResource SidebarBorderColor}"/>
    <SolidColorBrush x:Key="SidebarLogoAreaBrush" Color="{StaticResource SidebarLogoAreaColor}"/>

    <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>

    <SolidColorBrush x:Key="TopBarBgBrush" Color="{StaticResource TopBarBgColor}"/>
    <SolidColorBrush x:Key="TopBarBorderBrush" Color="{StaticResource TopBarBorderColor}"/>

    <SolidColorBrush x:Key="NavBarBgBrush" Color="{StaticResource NavBarBgColor}"/>
    <SolidColorBrush x:Key="NavBarHoverBrush" Color="{StaticResource NavBarHoverColor}"/>
    <SolidColorBrush x:Key="NavBarActiveBrush" Color="{StaticResource NavBarActiveColor}"/>
    <SolidColorBrush x:Key="NavBarTextBrush" Color="{StaticResource NavBarTextColor}"/>
    <SolidColorBrush x:Key="NavBarActiveTextBrush" Color="{StaticResource NavBarActiveTextColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource TextInverseColor}"/>

    <SolidColorBrush x:Key="InputTextBrush" Color="#FF1E293B"/>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessBgBrush" Color="{StaticResource SuccessBgColor}"/>
    <!-- Accounting Debit (مدين) / Credit (دائن) row & cell tints — reused app-wide -->
    <SolidColorBrush x:Key="AccountingDebitTintBrush" Color="{StaticResource SuccessBgColor}"/>
    <SolidColorBrush x:Key="AccountingCreditTintBrush" Color="{StaticResource DangerBgColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningBgBrush" Color="{StaticResource WarningBgColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerBgBrush" Color="{StaticResource DangerBgColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoBgBrush" Color="{StaticResource InfoBgColor}"/>

    <SolidColorBrush x:Key="AccentSalesBrush" Color="{StaticResource AccentSalesColor}"/>
    <SolidColorBrush x:Key="AccentOrdersBrush" Color="{StaticResource AccentOrdersColor}"/>
    <SolidColorBrush x:Key="AccentInventoryBrush" Color="{StaticResource AccentInventoryColor}"/>
    <SolidColorBrush x:Key="AccentReceivableBrush" Color="{StaticResource AccentReceivableColor}"/>
    <SolidColorBrush x:Key="AccentPayableBrush" Color="{StaticResource AccentPayableColor}"/>
    <SolidColorBrush x:Key="AccentCustomersBrush" Color="{StaticResource AccentCustomersColor}"/>

    <SolidColorBrush x:Key="AccentOrdersLightBrush" Color="{StaticResource AccentOrdersLightColor}"/>
    <SolidColorBrush x:Key="AccentInventoryLightBrush" Color="{StaticResource AccentInventoryLightColor}"/>
    <SolidColorBrush x:Key="AccentReceivableLightBrush" Color="{StaticResource AccentReceivableLightColor}"/>
    <SolidColorBrush x:Key="AccentPayableLightBrush" Color="{StaticResource AccentPayableLightColor}"/>
    <SolidColorBrush x:Key="AccentCustomersLightBrush" Color="{StaticResource AccentCustomersLightColor}"/>
    <SolidColorBrush x:Key="ChartBarLightBrush" Color="{StaticResource ChartBarLightColor}"/>
    <SolidColorBrush x:Key="ChartBarMidBrush" Color="{StaticResource ChartBarMidColor}"/>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  TYPOGRAPHY                                        -->
    <!-- ═══════════════════════════════════════════════════ -->

    <sys:Double x:Key="FontSizeXS">10</sys:Double>
    <sys:Double x:Key="FontSizeSM">12</sys:Double>
    <sys:Double x:Key="FontSizeMD">13</sys:Double>
    <sys:Double x:Key="FontSizeBase">14</sys:Double>
    <sys:Double x:Key="FontSizeLG">16</sys:Double>
    <sys:Double x:Key="FontSizeXL">18</sys:Double>
    <sys:Double x:Key="FontSize2XL">22</sys:Double>
    <sys:Double x:Key="FontSize3XL">28</sys:Double>

    <!-- Spacing scale -->
    <sys:Double x:Key="SpaceXS">4</sys:Double>
    <sys:Double x:Key="SpaceSM">8</sys:Double>
    <sys:Double x:Key="SpaceMD">12</sys:Double>
    <sys:Double x:Key="SpaceLG">16</sys:Double>
    <sys:Double x:Key="SpaceXL">24</sys:Double>
    <sys:Double x:Key="GridRowHeight">34</sys:Double>
    <sys:Double x:Key="GridHeaderHeight">32</sys:Double>
    <sys:Double x:Key="ControlHeightMD">32</sys:Double>

    <Thickness x:Key="PageMargin">16,12,16,16</Thickness>
    <Thickness x:Key="CardPaddingStandard">12</Thickness>
    <Thickness x:Key="CardGapMargin">0,0,12,12</Thickness>
    <Thickness x:Key="SectionBottomMargin">0,0,0,12</Thickness>

    <!-- Typography styles -->
    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
    </Style>
    <Style x:Key="PageSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
    </Style>
    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
    </Style>
    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
    </Style>
    <Style x:Key="KpiValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Typography.NumeralStyle" Value="Lining"/>
        <Setter Property="Language" Value="en-US"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  CORNER RADIUS                                     -->
    <!-- ═══════════════════════════════════════════════════ -->
    <CornerRadius x:Key="RadiusSM">4</CornerRadius>
    <CornerRadius x:Key="RadiusMD">6</CornerRadius>
    <CornerRadius x:Key="RadiusLG">8</CornerRadius>
    <CornerRadius x:Key="RadiusXL">12</CornerRadius>
    <CornerRadius x:Key="RadiusFull">100</CornerRadius>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  SHADOWS (via effects on elements)                 -->
    <!-- ═══════════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2" Direction="270"
                      Color="#000000" Opacity="0.06"/>
    <DropShadowEffect x:Key="ElevatedShadow" BlurRadius="20" ShadowDepth="4" Direction="270"
                      Color="#000000" Opacity="0.10"/>
    <DropShadowEffect x:Key="SubtleShadow" BlurRadius="6" ShadowDepth="1" Direction="270"
                      Color="#000000" Opacity="0.04"/>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  BUTTON STYLES                                     -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- Primary Button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Height" Value="{StaticResource ControlHeightMD}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary Button -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Height" Value="{StaticResource ControlHeightMD}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Height" Value="{StaticResource ControlHeightMD}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource DangerBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost Button -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Height" Value="{StaticResource ControlHeightMD}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Icon Button (square) -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="6" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource BorderLightBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Search box container -->
    <Style x:Key="SearchBoxStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <!-- Unified compact DataGrid -->
    <Style x:Key="EnterpriseDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="Language" Value="en-US"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeight" Value="{StaticResource GridRowHeight}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="RowBackground" Value="White"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
    </Style>

    <Style x:Key="EnterpriseColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Height" Value="{StaticResource GridHeaderHeight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="EnterpriseDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryVeryLightBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryVeryLightBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EnterpriseDataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Typography.NumeralStyle" Value="Lining"/>
        <Setter Property="Language" Value="en-US"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Default text color for all inputs (keep default WPF template — do NOT replace PART_ContentHost) -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Typography.NumeralStyle" Value="Lining"/>
        <Setter Property="Language" Value="en-US"/>
        <Setter Property="NumberSubstitution.CultureSource" Value="Override"/>
        <Setter Property="NumberSubstitution.CultureOverride" Value="en-US"/>
        <Setter Property="NumberSubstitution.Substitution" Value="European"/>
    </Style>

    <Style TargetType="{x:Type DatePickerTextBox}">
        <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Typography.NumeralStyle" Value="Lining"/>
        <Setter Property="Language" Value="en-US"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  TEXT INPUT STYLE                                  -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="EnterpriseInputStyle" TargetType="TextBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource PrimaryVeryLightBrush}"/>
        <Setter Property="SelectionTextBrush" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- China import cost entry — visible black borders (amount + note) -->
    <Style x:Key="EnterpriseCostEntryAmountInputStyle" TargetType="TextBox" BasedOn="{StaticResource EnterpriseInputStyle}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#FF1E293B"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EnterpriseCostEntryNoteInputStyle" TargetType="TextBox" BasedOn="{StaticResource EnterpriseInputStyle}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#FF1E293B"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EnterpriseSearchInputStyle" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EnterpriseDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Language" Value="en-US"/>
        <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="4,0"/>
        <Style.Resources>
            <Style TargetType="{x:Type DatePickerTextBox}">
                <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
                <Setter Property="CaretBrush" Value="{StaticResource InputTextBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- ComboBox Style -->
    <Style x:Key="EnterpriseComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Height" Value="{StaticResource ControlHeightMD}"/>
        <Style.Resources>
            <Style TargetType="TextBox">
                <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
                <Setter Property="CaretBrush" Value="{StaticResource InputTextBrush}"/>
            </Style>
            <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  CARD STYLE                                        -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="{StaticResource CardPaddingStandard}"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <Style x:Key="CardNoPaddingStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  BADGE STYLES                                      -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="BadgeSuccessStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SuccessBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="100"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <Style x:Key="BadgeWarningStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WarningBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="100"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <Style x:Key="BadgeDangerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DangerBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="100"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  SCROLLBAR STYLE                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#CBD5E1" CornerRadius="3" Margin="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  SEPARATOR STYLE                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="SeparatorStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,8"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!--  TABLE STYLES                                      -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Style x:Key="TableHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="16,10"/>
    </Style>

    <Style x:Key="TableRowStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Background" Value="White"/>
    </Style>

    <!-- ListBox for sidebar nav (no default styling) -->
    <Style x:Key="CleanListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style x:Key="CleanListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dashboard quick-action tile -->
    <Style x:Key="QuickActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryVeryLightBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Icon badge for quick actions and activity rows -->
    <Style x:Key="IconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="{StaticResource PrimaryVeryLightBrush}"/>
    </Style>

    <!--
        Latin digits (0-9) across Arabic RTL UI.
        NumberSubstitution.Substitution="European" is the decisive setting: WPF's text
        engine (DirectWrite) can render Western-digit characters (U+0030-0039) as
        Arabic-Indic GLYPHS at paint time when the effective Language/culture is Arabic
        and Substitution is left at its default "AsCulture"/"Context" mode — regardless
        of what the bound string actually contains. Forcing "European" bypasses that
        contextual glyph shaping entirely.
    -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Typography.NumeralStyle" Value="Lining"/>
        <Setter Property="Language" Value="en-US"/>
        <Setter Property="NumberSubstitution.CultureSource" Value="Override"/>
        <Setter Property="NumberSubstitution.CultureOverride" Value="en-US"/>
        <Setter Property="NumberSubstitution.Substitution" Value="European"/>
    </Style>
    <Style TargetType="{x:Type Label}">
        <Setter Property="Typography.NumeralStyle" Value="Lining"/>
        <Setter Property="Language" Value="en-US"/>
        <Setter Property="NumberSubstitution.CultureSource" Value="Override"/>
        <Setter Property="NumberSubstitution.CultureOverride" Value="en-US"/>
        <Setter Property="NumberSubstitution.Substitution" Value="European"/>
    </Style>
    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Typography.NumeralStyle" Value="Lining"/>
        <Setter Property="Language" Value="en-US"/>
        <Setter Property="NumberSubstitution.CultureSource" Value="Override"/>
        <Setter Property="NumberSubstitution.CultureOverride" Value="en-US"/>
        <Setter Property="NumberSubstitution.Substitution" Value="European"/>
    </Style>
    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Language" Value="en-US"/>
        <Setter Property="NumberSubstitution.CultureSource" Value="Override"/>
        <Setter Property="NumberSubstitution.CultureOverride" Value="en-US"/>
        <Setter Property="NumberSubstitution.Substitution" Value="European"/>
    </Style>
    <!-- Number substitution for text inputs moved into the main TextBox style above to avoid duplicate implicit styles. -->

</ResourceDictionary>
