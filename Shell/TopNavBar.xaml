<UserControl x:Class="ERPSystem.Shell.TopNavBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Border Background="{StaticResource NavBarBgBrush}" BorderThickness="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
                <Grid x:Name="NavItemsHost" HorizontalAlignment="Stretch" MinWidth="836"/>
            </ScrollViewer>

            <Button x:Name="BtnOverflow" Grid.Column="1"
                    Style="{StaticResource TopNavItemButtonStyle}"
                    Visibility="Collapsed"
                    MinWidth="72"
                    Padding="12,6"
                    Content="المزيد"/>
        </Grid>
    </Border>
</UserControl>
