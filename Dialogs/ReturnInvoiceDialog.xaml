<Window x:Class="ERPSystem.Dialogs.ReturnInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="620" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Border Width="32" Height="32" CornerRadius="8"
                            Background="{StaticResource WarningBrush}" Margin="0,0,12,0">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtTitle" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial" VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                        Width="32" Height="32" Padding="0" Click="BtnClose_Click">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <!-- Reference Invoice Info -->
                <Border Background="{StaticResource WarningBgBrush}"
                        BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="14,10" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="20" Foreground="{StaticResource WarningBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="TxtRefInvoiceLabel" FontSize="11"
                                       Foreground="{StaticResource WarningBrush}" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtRefInvoiceNum" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Return reason -->
                <TextBlock x:Name="TxtLblReason" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="7" Padding="10,8" Margin="0,0,0,16">
                    <ComboBox x:Name="CmbReason" BorderThickness="0" Background="Transparent"
                              FontSize="13" FontFamily="Segoe UI, Tahoma, Arial">
                        <ComboBoxItem x:Name="ReasonDefect" IsSelected="True"/>
                        <ComboBoxItem x:Name="ReasonWrong"/>
                        <ComboBoxItem x:Name="ReasonCustomerCancel"/>
                        <ComboBoxItem x:Name="ReasonOther"/>
                    </ComboBox>
                </Border>

                <!-- Returnable items header -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="TxtColItem" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Column="1" x:Name="TxtColInvoiced" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                               TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="TxtColReturn" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                               TextAlignment="Center"/>
                    <TextBlock Grid.Column="3" x:Name="TxtColAmount" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                               TextAlignment="Right"/>
                </Grid>

                <!-- Items list (built in code) -->
                <StackPanel x:Name="ReturnItemsPanel"/>

                <!-- Refund method -->
                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16"/>
                <TextBlock x:Name="TxtLblRefund" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="7" Padding="10,8" Margin="0,0,0,14">
                    <ComboBox x:Name="CmbRefund" BorderThickness="0" Background="Transparent"
                              FontSize="13" FontFamily="Segoe UI, Tahoma, Arial">
                        <ComboBoxItem x:Name="RefundCash" IsSelected="True"/>
                        <ComboBoxItem x:Name="RefundBalance"/>
                        <ComboBoxItem x:Name="RefundVoucher"/>
                    </ComboBox>
                </Border>

                <!-- Notes -->
                <TextBlock x:Name="TxtLblNotes" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="7" Padding="10,8">
                    <TextBox x:Name="TxtNotes" Background="Transparent" BorderThickness="0"
                             FontSize="12" FontFamily="Segoe UI" Height="56"
                             TextWrapping="Wrap" AcceptsReturn="True" MaxLength="300"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,0">
            <Grid VerticalAlignment="Center">
                <TextBlock x:Name="TxtReturnTotal" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource WarningBrush}"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Style="{StaticResource GhostButtonStyle}"
                            Height="36" Padding="16,0" Margin="0,0,8,0" Click="BtnClose_Click"/>
                    <Button x:Name="BtnConfirmReturn" Style="{StaticResource DangerButtonStyle}"
                            Height="36" Padding="20,0" Click="BtnConfirmReturn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
