<Window x:Class="ERPSystem.Dialogs.AddEditCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource AppBgBrush}">

    <Window.Resources>
        <!-- Field label style -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Required marker -->
        <Style x:Key="RequiredDotStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="*"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Margin" Value="3,0,0,5"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- Input field wrapper -->
        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- Text input inside border -->
        <Style x:Key="InputTextStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <!-- Title bar -->
            <RowDefinition Height="*"/>
            <!-- Form -->
            <RowDefinition Height="Auto"/>
            <!-- Validation msg -->
            <RowDefinition Height="64"/>
            <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- ── Title Bar ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="8"
                            Background="{StaticResource PrimaryBrush}" Margin="0,0,12,0">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtDialogTitle"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                        Width="32" Height="32" Padding="0" Click="BtnClose_Click">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Form ── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,0">
            <StackPanel>

                <!-- Section: Basic Info -->
                <TextBlock x:Name="TxtSectionBasic"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="Segoe UI" Margin="0,0,0,14"
/>

                <!-- Customer name (required) -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtLabelName" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Style="{StaticResource RequiredDotStyle}"/>
                        </StackPanel>
                        <Border Style="{StaticResource InputBorderStyle}" x:Name="NameBorder">
                            <TextBox x:Name="TxtName" Style="{StaticResource InputTextStyle}"
                                     MaxLength="100" TextChanged="TxtName_TextChanged"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="TxtLabelCode" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox x:Name="TxtCode" Style="{StaticResource InputTextStyle}"
                                     MaxLength="20"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Phone + Phone2 -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtLabelPhone" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox x:Name="TxtPhone" Style="{StaticResource InputTextStyle}" MaxLength="15"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="TxtLabelPhone2" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox x:Name="TxtPhone2" Style="{StaticResource InputTextStyle}" MaxLength="15"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Account Type + Status -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtLabelType" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}" Padding="6,4">
                            <ComboBox x:Name="CmbType" BorderThickness="0" Background="Transparent"
                                      FontSize="13" FontFamily="Segoe UI, Tahoma, Arial"
                                      SelectionChanged="CmbType_SelectionChanged">
                                <ComboBoxItem x:Name="CmbTypeCash" IsSelected="True"/>
                                <ComboBoxItem x:Name="CmbTypeCredit"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="TxtLabelCreditLimit" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}" x:Name="CreditLimitBorder">
                            <TextBox x:Name="TxtCreditLimit" Style="{StaticResource InputTextStyle}"
                                     Text="0" MaxLength="12"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Address + Region -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtLabelAddress" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox x:Name="TxtAddress" Style="{StaticResource InputTextStyle}" MaxLength="200"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="TxtLabelRegion" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox x:Name="TxtRegion" Style="{StaticResource InputTextStyle}" MaxLength="50"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Sales Rep -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtLabelRep" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox x:Name="TxtRep" Style="{StaticResource InputTextStyle}" MaxLength="80"/>
                        </Border>
                    </StackPanel>
                    <!-- Tax number (future-ready) -->
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="TxtLabelTax" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox x:Name="TxtTaxNumber" Style="{StaticResource InputTextStyle}" MaxLength="20"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Notes -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock x:Name="TxtLabelNotes" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="TxtNotes" Style="{StaticResource InputTextStyle}"
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                 MaxLength="300" VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </StackPanel>

                <!-- Future placeholders (collapsed but wired) -->
                <Border x:Name="FuturePlaceholders" Visibility="Collapsed">
                    <!-- TODO: attach pricing level -->
                    <!-- TODO: attach customer group -->
                    <!-- TODO: attach loyalty profile -->
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Validation Message ── -->
        <Border Grid.Row="2" x:Name="ValidationBanner" Visibility="Collapsed"
                Background="{StaticResource DangerBgBrush}"
                BorderBrush="{StaticResource DangerBrush}" BorderThickness="0,1,0,1"
                Padding="20,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{StaticResource DangerBrush}" Margin="0,0,8,0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtValidationMsg"
                           FontSize="12" Foreground="{StaticResource DangerBrush}"
                           FontFamily="Segoe UI, Tahoma, Arial" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Action Buttons ── -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock x:Name="TxtRequiredNote"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Style="{StaticResource SecondaryButtonStyle}"
                            Height="36" Padding="20,0" Margin="0,0,8,0"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" Padding="24,0"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
