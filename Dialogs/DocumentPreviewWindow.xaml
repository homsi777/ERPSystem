<Window x:Class="ERPSystem.Dialogs.DocumentPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="معاينة المستند"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Background="{StaticResource AppBgBrush}"
        FontFamily="Segoe UI, Tahoma, Arial">

    <Border Style="{StaticResource CardStyle}" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{StaticResource PrimaryVeryLightBrush}" Margin="0,0,12,0">
                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTitle" Text="معاينة المستند"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TxtFormat" Text="PDF"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Document Preview" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="This template is ready."
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock Text="Real printing will be activated during the Document Engine phase."
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,8,0,0" MaxWidth="360"/>
                    <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Height="120" Width="280" Margin="0,20,0,0">
                        <TextBlock x:Name="TxtDocName" Text="فاتورة بيع"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>
            </Border>

            <Button Grid.Row="2" Content="إغلاق" Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Left" Margin="0,16,0,0"
                    Width="100" Height="36" IsDefault="True" Click="BtnClose_Click"/>
        </Grid>
    </Border>
</Window>
