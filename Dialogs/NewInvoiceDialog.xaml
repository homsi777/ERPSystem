<Window x:Class="ERPSystem.Dialogs.NewInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="820" Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinWidth="700" MinHeight="560"
        ShowInTaskbar="False"
        Background="{StaticResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Title bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="60"/>   <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="32" CornerRadius="8"
                            Background="{StaticResource PrimaryBrush}" Margin="0,0,12,0">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtTitle" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,4" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtInvoiceNum" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource GhostButtonStyle}" Width="32" Height="32"
                            Padding="0" Click="BtnClose_Click">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- Lines -->
                <ColumnDefinition Width="280"/>    <!-- Right sidebar: customer + totals -->
            </Grid.ColumnDefinitions>

            <!-- Left: Customer selector + Lines grid -->
            <Grid Grid.Column="0" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Customer + type row -->
                    <RowDefinition Height="Auto"/>   <!-- Lines header -->
                    <RowDefinition Height="*"/>      <!-- Lines table -->
                    <RowDefinition Height="Auto"/>   <!-- Add line + notes -->
                </Grid.RowDefinitions>

                <!-- Customer + Invoice type row -->
                <Border Grid.Row="0" Padding="20,14"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <!-- Customer search -->
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TxtLabelCustomer" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,5"/>
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="7" Height="34">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center" Margin="10,0,6,0"/>
                                    <TextBox Grid.Column="1" x:Name="TxtCustomerSearch"
                                             Background="Transparent" BorderThickness="0"
                                             FontSize="13" FontFamily="Segoe UI, Tahoma, Arial"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}"
                                            Width="28" Padding="0" Height="28"
                                            x:Name="BtnSelectCustomer" Click="BtnSelectCustomer_Click">
                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Invoice type -->
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="TxtLabelType" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,5"/>
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="6,4" Height="34">
                                <ComboBox x:Name="CmbType" BorderThickness="0" Background="Transparent"
                                          FontSize="13" FontFamily="Segoe UI, Tahoma, Arial">
                                    <ComboBoxItem x:Name="CmbCash" IsSelected="True"/>
                                    <ComboBoxItem x:Name="CmbCredit"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <!-- Payment method -->
                        <StackPanel Grid.Column="4">
                            <TextBlock x:Name="TxtLabelPayMethod" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,5"/>
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="7" Padding="6,4" Height="34">
                                <ComboBox x:Name="CmbPayMethod" BorderThickness="0" Background="Transparent"
                                          FontSize="13" FontFamily="Segoe UI, Tahoma, Arial">
                                    <ComboBoxItem x:Name="CmbPayCash" IsSelected="True"/>
                                    <ComboBoxItem x:Name="CmbPayCard"/>
                                    <ComboBoxItem x:Name="CmbPayTransfer"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Lines table header -->
                <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="20,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="TxtColItem" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                        <TextBlock Grid.Column="1" x:Name="TxtColQty" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                   TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="TxtColPrice" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                   TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" x:Name="TxtColDiscount" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                   TextAlignment="Right"/>
                        <TextBlock Grid.Column="4" x:Name="TxtColTotal" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                   TextAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Lines area (ScrollViewer with placeholder rows) -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0">
                    <StackPanel x:Name="LinesContainer" Background="White">
                        <!-- Sample line row structure (populated in code) -->
                        <Border Padding="20,10" BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ابحث أو امسح باركود الصنف..."
                                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="—" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="—" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="—" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="—" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <!-- TODO: attach invoice lines data binding -->
                        <!-- TODO: attach price list / discount policy -->
                    </StackPanel>
                </ScrollViewer>

                <!-- Add line + Notes -->
                <Border Grid.Row="3" Padding="16,10"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnAddLine"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="32" Padding="12,0" Click="BtnAddLine_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnAddLine" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Border Grid.Column="2" Background="White"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="8,4">
                            <TextBox x:Name="TxtNotes" Background="Transparent" BorderThickness="0"
                                     FontSize="12" FontFamily="Segoe UI, Tahoma, Arial"
                                     Foreground="{StaticResource TextPrimaryBrush}" MaxLength="200"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right sidebar: Totals + post options -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <StackPanel Margin="16,16,16,16">
                    <!-- Totals -->
                    <TextBlock x:Name="TxtTotalsTitle" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,6">
                        <TextBlock x:Name="TxtLblSubtotal" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtSubtotal" Text="0.00" FontSize="12"
                                   HorizontalAlignment="Right" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Segoe UI"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock x:Name="TxtLblDiscount" FontSize="12"
                                   Foreground="{StaticResource SuccessBrush}" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtDiscount" Text="0.00" FontSize="12"
                                   HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}"
                                   FontFamily="Segoe UI"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock x:Name="TxtLblVat" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtVat" Text="0.00" FontSize="12"
                                   HorizontalAlignment="Right" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Segoe UI"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                    <!-- Grand Total -->
                    <Border Background="{StaticResource PrimaryVeryLightBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,16">
                        <Grid>
                            <TextBlock x:Name="TxtLblGrand" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtGrand" Text="0.00" FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                        </Grid>
                    </Border>

                    <!-- Payment input -->
                    <TextBlock x:Name="TxtLblPaid" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI" Margin="0,0,0,5"/>
                    <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="7" Padding="10,8" Margin="0,0,0,16">
                        <TextBox x:Name="TxtPaidAmount" Text="0.00" Background="Transparent"
                                 BorderThickness="0" FontSize="16" FontWeight="Bold"
                                 FontFamily="Segoe UI" Foreground="{StaticResource TextPrimaryBrush}"
                                 TextAlignment="Right"/>
                    </Border>

                    <!-- TODO: attach branch filtering -->
                    <!-- TODO: attach salesperson filter -->
                    <!-- TODO: attach approval workflow -->
                    <!-- TODO: attach opening balance allocation awareness -->
                </StackPanel>
            </Border>
        </Grid>

        <!-- Action buttons -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,0">
            <Grid VerticalAlignment="Center">
                <TextBlock x:Name="TxtValidation" FontSize="12"
                           Foreground="{StaticResource DangerBrush}" FontFamily="Segoe UI"
                           VerticalAlignment="Center" Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnSaveDraft" Style="{StaticResource SecondaryButtonStyle}"
                            Height="36" Padding="20,0" Margin="0,0,8,0" Click="BtnSaveDraft_Click"/>
                    <Button x:Name="BtnPost" Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" Padding="24,0" Margin="0,0,8,0" Click="BtnPost_Click"/>
                    <Button x:Name="BtnCancelDialog" Style="{StaticResource GhostButtonStyle}"
                            Height="36" Padding="16,0" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
