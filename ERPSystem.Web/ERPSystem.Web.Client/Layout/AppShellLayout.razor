@inject NavigationManager Navigation

<MudRTLProvider RightToLeft="true">
    <MudThemeProvider Theme="ErpTheme.Default" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <MudLayout Class="erp-shell">
        <MudAppBar Elevation="0" Dense="true" Class="erp-header">
            <MudText Typo="Typo.h6" Class="erp-brand">ERP PRO</MudText>
            <MudSpacer />
            <MudMenu AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                <ActivatorContent>
                    <MudButton Variant="Variant.Text"
                               EndIcon="@Icons.Material.Filled.ArrowDropDown"
                               Class="erp-touch-target">
                        مدير النظام
                    </MudButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Logout" Disabled="true">
                        تسجيل الخروج (قريباً)
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
        </MudAppBar>

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudToolBar Dense="true" Class="erp-topnav">
                @foreach (var item in NavItems)
                {
                    <MudButton Href="@item.Href"
                               Variant="@(IsActive(item.Href) ? Variant.Filled : Variant.Text)"
                               Color="@(IsActive(item.Href) ? Color.Primary : Color.Inherit)"
                               StartIcon="@item.Icon"
                               Class="erp-nav-btn">
                        @item.Label
                    </MudButton>
                }
            </MudToolBar>
        </MudHidden>

        <MudMainContent Class="erp-main erp-main-with-bottom-nav">
            @ChildContent
        </MudMainContent>

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <nav class="erp-bottom-nav">
                @foreach (var item in NavItems)
                {
                    <a href="@item.Href" class="erp-bottom-nav-item @(IsActive(item.Href) ? "active" : "")">
                        <MudIcon Icon="@item.Icon" Size="Size.Medium" />
                        <span>@item.Label</span>
                    </a>
                }
            </nav>
        </MudHidden>
    </MudLayout>
</MudRTLProvider>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private static readonly ShellNavItem[] NavItems =
    [
        new("رئيسية", "/", Icons.Material.Filled.Home),
        new("المخزون", "/inventory", Icons.Material.Filled.Inventory2),
        new("العملاء", "/customers", Icons.Material.Filled.People),
        new("طلبات الصين", "/china", Icons.Material.Filled.Sailing),
        new("التسليم", "/delivery", Icons.Material.Filled.LocalShipping)
    ];

    private bool IsActive(string href)
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        var target = href.TrimStart('/').TrimEnd('/');

        if (string.IsNullOrEmpty(target))
            return string.IsNullOrEmpty(relative);

        return relative.Equals(target, StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith($"{target}/", StringComparison.OrdinalIgnoreCase);
    }
}
