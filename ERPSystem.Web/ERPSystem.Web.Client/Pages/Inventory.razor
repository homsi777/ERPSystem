@page "/inventory"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ApiClient ApiClient

<PageTitle>استعلام المخزون</PageTitle>

<AppShellLayout>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    <MudText Typo="Typo.h4" Class="mb-4">استعلام المخزون</MudText>

    @if (_loading)
    {
        <LoadingState Message="جاري تحميل بيانات المخزون..." />
    }
    else if (_error is not null)
    {
        <ErrorState Message="@_error" OnRetry="LoadAsync" />
    }
    else if (_items.Count == 0)
    {
        <EmptyState Message="لا توجد بيانات مخزون" />
    }
    else
    {
        <MudTable Items="_items" Hover="true" Striped="true" Dense="true" FixedHeader="true" Height="calc(100vh - 220px)">
            <HeaderContent>
                <MudTh>اسم القماش</MudTh>
                <MudTh>الكود</MudTh>
                <MudTh>اللون</MudTh>
                <MudTh>المستودع</MudTh>
                <MudTh>الحاوية</MudTh>
                <MudTh Style="text-align:center">عدد الأثواب</MudTh>
                <MudTh Style="text-align:end">الأمتار</MudTh>
                <MudTh Style="text-align:end">المتاح</MudTh>
                <MudTh Style="text-align:end">القيمة</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="اسم القماش">@context.FabricName</MudTd>
                <MudTd DataLabel="الكود">@context.FabricCode</MudTd>
                <MudTd DataLabel="اللون">@context.ColorName</MudTd>
                <MudTd DataLabel="المستودع">@context.WarehouseName</MudTd>
                <MudTd DataLabel="الحاوية">@context.ContainerNumber</MudTd>
                <MudTd DataLabel="عدد الأثواب" Style="text-align:center">@context.RollCount</MudTd>
                <MudTd DataLabel="الأمتار" Style="text-align:end">@context.TotalMeters.ToString("N2")</MudTd>
                <MudTd DataLabel="المتاح" Style="text-align:end">@context.AvailableMeters.ToString("N2")</MudTd>
                <MudTd DataLabel="القيمة" Style="text-align:end">@context.InventoryValue.ToString("N2")</MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>
</AppShellLayout>

@code {
    private bool _loading = true;
    private string? _error;
    private List<FabricStockBalanceModel> _items = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var result = await ApiClient.GetAsync<List<FabricStockBalanceModel>>("api/v1/inventory/stock");

        _loading = false;

        if (result.IsSuccess)
            _items = result.Value ?? [];
        else
            _error = result.ErrorMessage;
    }
}
