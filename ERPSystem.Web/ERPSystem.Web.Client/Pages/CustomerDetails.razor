@page "/customers/{Id:guid}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>@(_customer?.NameAr ?? "تفاصيل العميل")</PageTitle>

<AppShellLayout>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowForward"
               Variant="Variant.Text"
               Color="Color.Primary"
               OnClick="@(() => Navigation.NavigateTo("/customers"))"
               Class="mb-3">
        العودة للقائمة
    </MudButton>

    @if (_loadingDetails)
    {
        <LoadingState Message="جاري تحميل بيانات العميل..." />
    }
    else if (_detailsError is not null)
    {
        <ErrorState Message="@_detailsError" OnRetry="LoadDetailsAsync" />
    }
    else if (_customer is not null)
    {
        <MudText Typo="Typo.h4" Class="mb-4">@_customer.NameAr</MudText>

        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 erp-state-card" Elevation="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">الرصيد</MudText>
                    <MudText Typo="Typo.h6">@_customer.Balance.ToString("N2")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 erp-state-card" Elevation="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">حد الائتمان</MudText>
                    <MudText Typo="Typo.h6">@_customer.CreditLimit.ToString("N2")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 erp-state-card" Elevation="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">النوع</MudText>
                    <MudText Typo="Typo.h6">@CustomerDisplay.TypeLabel(_customer.Type)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 erp-state-card" Elevation="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">الكود</MudText>
                    <MudText Typo="Typo.h6">@_customer.Code</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-3 mb-4" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2" Wrap="Wrap.Wrap">
                <MudDatePicker @bind-Date="_fromDate" Label="من تاريخ" Clearable="true" />
                <MudDatePicker @bind-Date="_toDate" Label="إلى تاريخ" Clearable="true" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="ApplyDateFilterAsync"
                           Class="erp-touch-target">
                    تطبيق
                </MudButton>
            </MudStack>
        </MudPaper>

        <MudTabs ActivePanelIndex="_activeTab" ActivePanelIndexChanged="OnTabChangedAsync" Rounded="true" ApplyEffectsToContainer="true">
            <MudTabPanel Text="تفاصيل المبيعات">
                @if (_loadingSales)
                {
                    <LoadingState Message="جاري تحميل تفاصيل المبيعات..." />
                }
                else if (_salesError is not null)
                {
                    <ErrorState Message="@_salesError" OnRetry="LoadSalesAsync" />
                }
                else if (_salesItems.Count == 0)
                {
                    <EmptyState Message="لا توجد مبيعات في الفترة المحددة" />
                }
                else
                {
                    <MudTable Items="_salesItems" Hover="true" Striped="true" Dense="true">
                        <HeaderContent>
                            <MudTh>التاريخ</MudTh>
                            <MudTh>القماش</MudTh>
                            <MudTh>الكود</MudTh>
                            <MudTh>اللون</MudTh>
                            <MudTh Style="text-align:end">السعر</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="التاريخ">@context.SaleDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd DataLabel="القماش">@context.FabricName</MudTd>
                            <MudTd DataLabel="الكود">@context.FabricCode</MudTd>
                            <MudTd DataLabel="اللون">@context.ColorName</MudTd>
                            <MudTd DataLabel="السعر" Style="text-align:end">@context.UnitPrice.ToString("N2")</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            <MudTabPanel Text="كشف الحساب">
                @if (_loadingStatement)
                {
                    <LoadingState Message="جاري تحميل كشف الحساب..." />
                }
                else if (_statementError is not null)
                {
                    <ErrorState Message="@_statementError" OnRetry="LoadStatementAsync" />
                }
                else if (_statement is null || _statement.Lines.Count == 0)
                {
                    <EmptyState Message="لا توجد حركات في كشف الحساب للفترة المحددة" />
                }
                else
                {
                    <MudGrid Class="mb-3">
                        <MudItem xs="6" sm="4">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">الرصيد الافتتاحي</MudText>
                            <MudText Typo="Typo.subtitle1">@_statement.OpeningBalance.ToString("N2")</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">الرصيد الختامي</MudText>
                            <MudText Typo="Typo.subtitle1">@_statement.ClosingBalance.ToString("N2")</MudText>
                        </MudItem>
                    </MudGrid>

                    <MudTable Items="_statement.Lines" Hover="true" Striped="true" Dense="true">
                        <HeaderContent>
                            <MudTh>التاريخ</MudTh>
                            <MudTh>نوع المستند</MudTh>
                            <MudTh>رقم المستند</MudTh>
                            <MudTh Style="text-align:end">مدين</MudTh>
                            <MudTh Style="text-align:end">دائن</MudTh>
                            <MudTh Style="text-align:end">الرصيد</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="التاريخ">@context.EntryDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd DataLabel="نوع المستند">@CustomerDisplay.DocumentTypeLabel(context.DocumentType)</MudTd>
                            <MudTd DataLabel="رقم المستند">@context.DocumentNumber</MudTd>
                            <MudTd DataLabel="مدين" Style="text-align:end">@context.Debit.ToString("N2")</MudTd>
                            <MudTd DataLabel="دائن" Style="text-align:end">@context.Credit.ToString("N2")</MudTd>
                            <MudTd DataLabel="الرصيد" Style="text-align:end">@context.RunningBalance.ToString("N2")</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>
</AppShellLayout>

@code {
    [Parameter] public Guid Id { get; set; }

    private CustomerDetailsModel? _customer;
    private bool _loadingDetails = true;
    private string? _detailsError;

    private int _activeTab;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    private List<CustomerSalesDetailModel> _salesItems = [];
    private bool _loadingSales;
    private string? _salesError;

    private CustomerStatementModel? _statement;
    private bool _loadingStatement;
    private string? _statementError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDetailsAsync();
        await LoadSalesAsync();
    }

    private async Task OnTabChangedAsync(int index)
    {
        _activeTab = index;
        if (index == 1)
            await LoadStatementAsync();
    }

    private async Task LoadDetailsAsync()
    {
        _loadingDetails = true;
        _detailsError = null;
        StateHasChanged();

        var result = await ApiClient.GetAsync<CustomerDetailsModel>($"api/v1/customers/{Id}");

        _loadingDetails = false;

        if (result.IsSuccess)
            _customer = result.Value;
        else
            _detailsError = result.ErrorMessage;
    }

    private async Task ApplyDateFilterAsync()
    {
        if (_activeTab == 0)
            await LoadSalesAsync();
        else
            await LoadStatementAsync();
    }

    private async Task LoadSalesAsync()
    {
        _loadingSales = true;
        _salesError = null;
        StateHasChanged();

        var result = await ApiClient.GetAsync<List<CustomerSalesDetailModel>>(BuildSalesUrl());

        _loadingSales = false;

        if (result.IsSuccess)
            _salesItems = result.Value?.ToList() ?? [];
        else
            _salesError = result.ErrorMessage;
    }

    private async Task LoadStatementAsync()
    {
        _loadingStatement = true;
        _statementError = null;
        StateHasChanged();

        var result = await ApiClient.GetAsync<CustomerStatementModel>(BuildStatementUrl());

        _loadingStatement = false;

        if (result.IsSuccess)
            _statement = result.Value;
        else
            _statementError = result.ErrorMessage;
    }

    private string BuildSalesUrl()
    {
        var url = $"api/v1/customers/{Id}/sales-details";
        return AppendDateQuery(url);
    }

    private string BuildStatementUrl()
    {
        var url = $"api/v1/customers/{Id}/statement";
        return AppendDateQuery(url);
    }

    private string AppendDateQuery(string url)
    {
        var parts = new List<string>();
        if (_fromDate.HasValue)
            parts.Add($"from={_fromDate.Value:yyyy-MM-dd}");
        if (_toDate.HasValue)
            parts.Add($"to={_toDate.Value:yyyy-MM-dd}");
        return parts.Count == 0 ? url : $"{url}?{string.Join("&", parts)}";
    }
}
