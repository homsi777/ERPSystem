@page "/customers"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>العملاء</PageTitle>

<AppShellLayout>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-2">
    <MudText Typo="Typo.h4" Class="mb-4">العملاء</MudText>

    <MudPaper Class="pa-3 mb-4" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudTextField @bind-Value="_search"
                          Label="بحث"
                          Placeholder="اسم أو كود العميل"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          OnKeyUp="OnSearchKeyUp"
                          Class="flex-grow-1" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SearchAsync"
                       Class="erp-touch-target">
                بحث
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <LoadingState Message="جاري تحميل قائمة العملاء..." />
    }
    else if (_error is not null)
    {
        <ErrorState Message="@_error" OnRetry="LoadAsync" />
    }
    else if (_items.Count == 0)
    {
        <EmptyState Message="لا توجد عملاء" />
    }
    else
    {
        <MudTable Items="_items" Hover="true" Striped="true" Dense="true" FixedHeader="true" Height="calc(100vh - 300px)">
            <HeaderContent>
                <MudTh>الكود</MudTh>
                <MudTh>الاسم</MudTh>
                <MudTh>النوع</MudTh>
                <MudTh>الحالة</MudTh>
                <MudTh Style="text-align:end">الرصيد</MudTh>
                <MudTh Style="text-align:end">حد الائتمان</MudTh>
                <MudTh Style="text-align:center">إجراء</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="الكود">@context.Code</MudTd>
                <MudTd DataLabel="الاسم">@context.NameAr</MudTd>
                <MudTd DataLabel="النوع">@CustomerDisplay.TypeLabel(context.Type)</MudTd>
                <MudTd DataLabel="الحالة">@CustomerDisplay.StatusLabel(context.Status)</MudTd>
                <MudTd DataLabel="الرصيد" Style="text-align:end">@context.Balance.ToString("N2")</MudTd>
                <MudTd DataLabel="حد الائتمان" Style="text-align:end">@context.CreditLimit.ToString("N2")</MudTd>
                <MudTd DataLabel="إجراء" Style="text-align:center">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="@(() => GoToDetails(context.Id))">
                        تفاصيل
                    </MudButton>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }"
                               InfoFormat="عرض {first_item}-{last_item} من {all_items}"
                               RowsPerPageString="صفوف لكل صفحة" />
            </PagerContent>
        </MudTable>
    }
</MudContainer>
</AppShellLayout>

@code {
    private bool _loading = true;
    private string? _error;
    private string _search = "";
    private List<CustomerListModel> _items = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await SearchAsync();
    }

    private async Task SearchAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var query = BuildListUrl();
        var result = await ApiClient.GetAsync<PagedResultModel<CustomerListModel>>(query);

        _loading = false;

        if (result.IsSuccess)
            _items = result.Value?.Items.ToList() ?? [];
        else
            _error = result.ErrorMessage;
    }

    private string BuildListUrl()
    {
        var query = "api/v1/customers?page=1&pageSize=50";
        if (!string.IsNullOrWhiteSpace(_search))
            query += $"&search={Uri.EscapeDataString(_search.Trim())}";
        return query;
    }

    private void GoToDetails(Guid id) => Navigation.NavigateTo($"/customers/{id}");
}
