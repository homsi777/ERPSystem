@switch (Name)
{
    case "home":
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M4 10.5 12 4l8 6.5V20a1 1 0 0 1-1 1h-5v-6H10v6H5a1 1 0 0 1-1-1v-9.5Z" stroke-linejoin="round" />
        </svg>
        break;
    case "inventory":
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5v-9Z" stroke-linejoin="round" />
            <path d="M12 12v9M4 7.5 12 12l8-4.5" stroke-linejoin="round" />
        </svg>
        break;
    case "customers":
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="9" cy="8" r="3.5" />
            <path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke-linecap="round" />
            <path d="M16 11.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM14.5 20c.3-2.2 2-3.8 4.5-3.8" stroke-linecap="round" />
        </svg>
        break;
    case "china":
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M3 18h18M5 18V9l7-4 7 4v9" stroke-linejoin="round" />
            <path d="M9 13h6M9 16h4" stroke-linecap="round" />
        </svg>
        break;
    case "delivery":
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M3 7h11v9H3V7Z" stroke-linejoin="round" />
            <path d="M14 10h4l3 3v3h-7v-6Z" stroke-linejoin="round" />
            <circle cx="7" cy="18" r="1.5" fill="currentColor" stroke="none" />
            <circle cx="17" cy="18" r="1.5" fill="currentColor" stroke="none" />
        </svg>
        break;
    case "fabric":
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M6 4h12v16l-3-2-3 2-3-2-3 2V4Z" stroke-linejoin="round" />
            <path d="M9 8h6M9 12h6" stroke-linecap="round" />
        </svg>
        break;
    case "inbox":
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M4 7h16v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7Z" stroke-linejoin="round" />
            <path d="M4 7l4 5h8l4-5" stroke-linejoin="round" />
        </svg>
        break;
    case "alert":
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 8v5M12 16h.01" stroke-linecap="round" />
        </svg>
        break;
    default:
        <svg class="erp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
        </svg>
        break;
}

@code {
    [Parameter] public string Name { get; set; } = "";
}
