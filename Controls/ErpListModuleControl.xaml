<UserControl x:Class="ERPSystem.Controls.ErpListModuleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{StaticResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: primary actions only -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="{StaticResource CardPaddingStandard}">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnPrimary" Style="{StaticResource PrimaryButtonStyle}"
                        Height="32" Padding="12,0" Margin="0,0,6,0" Click="BtnPrimary_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtPrimaryBtn" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource GhostButtonStyle}" Height="32" Padding="10,0"
                        Click="BtnExport_Click" ToolTip="تصدير">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="تصدير" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Search + filters -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="{StaticResource CardPaddingStandard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource SearchBoxStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="8,0,6,0"/>
                        <TextBox Grid.Column="1" x:Name="TxtSearch" Background="Transparent"
                                 BorderThickness="0" FontSize="12" VerticalAlignment="Center"
                                 Tag="بحث..."
                                 TextChanged="TxtSearch_TextChanged"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" x:Name="FilterExtrasPanel" Orientation="Horizontal"
                            Margin="8,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Table -->
        <Border Grid.Row="2" Background="White">
            <Grid>
                <DataGrid x:Name="MainGrid" Style="{StaticResource EnterpriseDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource EnterpriseColumnHeaderStyle}"
                          RowStyle="{StaticResource EnterpriseDataGridRowStyle}"
                          CellStyle="{StaticResource EnterpriseDataGridCellStyle}"/>
                <Border x:Name="EmptyStatePanel" Background="White" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtEmptyIcon" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="28" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtEmptyMessage" Text="لا توجد سجلات"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" FontFamily="Segoe UI, Tahoma, Arial"/>
                        <Button x:Name="BtnEmptyAction" Style="{StaticResource PrimaryButtonStyle}"
                                Height="32" Margin="0,10,0,0" Visibility="Collapsed"
                                Click="BtnPrimary_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="{StaticResource CardPaddingStandard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtRecordCount" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="Segoe UI, Tahoma, Arial" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="TxtFilterSummary" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="Segoe UI, Tahoma, Arial" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
