<UserControl x:Class="ERPSystem.Controls.ModuleShellControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{StaticResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="{StaticResource CardPaddingStandard}">
            <StackPanel>
                <TextBlock x:Name="TxtBreadcrumb" Style="{StaticResource CaptionTextStyle}"/>
                <TextBlock x:Name="TxtPageTitle" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Segoe UI, Tahoma, Arial" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="1" x:Name="ContentHost"/>
    </Grid>
</UserControl>
