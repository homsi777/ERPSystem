<UserControl x:Class="ERPSystem.Controls.EnterpriseTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="8"
            Effect="{StaticResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Compact toolbar -->
            <Border Grid.Row="0" Padding="16,6"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SearchBoxStyle}" Width="220" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="8,0,6,0"/>
                            <TextBox Grid.Column="1" x:Name="TxtSearch" Background="Transparent"
                                     BorderThickness="0" FontSize="12" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButtonStyle}" Height="32" Padding="10,0" FontSize="12" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtExportBtn" Text="تصدير" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnAddNew" Style="{StaticResource PrimaryButtonStyle}"
                                Height="32" Padding="10,0" FontSize="12" Click="BtnAddNew_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtAddNew" Text="جديد" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" x:Name="MainGrid"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource EnterpriseColumnHeaderStyle}"
                      RowStyle="{StaticResource EnterpriseDataGridRowStyle}"
                      CellStyle="{StaticResource EnterpriseDataGridCellStyle}"
                      MinHeight="160"/>

            <Border Grid.Row="2" Padding="16,5"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="TxtRecordCount" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="Segoe UI, Tahoma, Arial" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
