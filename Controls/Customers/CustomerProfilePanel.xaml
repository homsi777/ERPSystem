<UserControl x:Class="ERPSystem.Controls.Customers.CustomerProfilePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1,0,0,0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header: avatar + name + code -->
                <RowDefinition Height="*"/>
                <!-- Scrollable content -->
                <RowDefinition Height="Auto"/>
                <!-- Quick actions bar -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <!-- Avatar circle + name row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="40" Height="40" CornerRadius="20"
                                    Background="{StaticResource PrimaryBrush}"
                                    Margin="0,0,12,0">
                                <TextBlock x:Name="TxtAvatar" Text="م"
                                           FontSize="18" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtProfileName"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI, Tahoma, Arial"
                                           TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                <TextBlock x:Name="TxtProfileCode"
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Type + Status badges -->
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="BadgeType" CornerRadius="4" Padding="7,3" Margin="0,0,6,0">
                                <TextBlock x:Name="TxtBadgeType" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="BadgeStatus" CornerRadius="4" Padding="7,3" Margin="0,0,6,0">
                                <TextBlock x:Name="TxtBadgeStatus" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <!-- Over-limit warning -->
                            <Border x:Name="BadgeOverLimit" CornerRadius="4" Padding="7,3"
                                    Background="{StaticResource DangerBgBrush}"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{StaticResource DangerBrush}" Margin="0,0,4,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtOverLimit" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource DangerBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Phone quick copy -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtProfilePhone"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="TxtProfileRegion"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable Content ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,0,8">

                    <!-- Financial Snapshot Section -->
                    <Border Padding="16,14" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock x:Name="TxtFinancialTitle"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,10"
/>

                            <!-- Balance (prominent) -->
                            <Border x:Name="BalanceBorder" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                                <Grid>
                                    <TextBlock x:Name="TxtBalanceLabel"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="TxtBalanceValue"
                                               FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Right"
                                               FontFamily="Segoe UI"/>
                                </Grid>
                            </Border>

                            <!-- Credit limit row -->
                            <Border x:Name="CreditLimitRow" Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock x:Name="TxtCreditLimitLabel"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="TxtCreditLimitValue"
                                                   FontSize="12" HorizontalAlignment="Right"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontFamily="Segoe UI"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock x:Name="TxtAvailableCreditLabel"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="TxtAvailableCreditValue"
                                                   FontSize="12" HorizontalAlignment="Right"
                                                   FontFamily="Segoe UI"/>
                                    </Grid>
                                    <!-- Credit usage bar -->
                                    <Border Height="5" CornerRadius="3"
                                            Background="{StaticResource BorderLightBrush}"
                                            Margin="0,0,0,10">
                                        <Border x:Name="CreditUsageBar" CornerRadius="3"
                                                HorizontalAlignment="Left" Background="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Other stats: invoices + last activity -->
                            <Grid Margin="0,0,0,4">
                                <TextBlock x:Name="TxtInvoicesLabel"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtInvoicesValue"
                                           FontSize="12" HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                            <Grid>
                                <TextBlock x:Name="TxtLastActivityLabel"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtLastActivityValue"
                                           FontSize="12" HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Contact Info Section -->
                    <Border Padding="16,14" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock x:Name="TxtContactTitle"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,10"
/>

                            <Grid Margin="0,0,0,6" x:Name="Phone2Row">
                                <TextBlock x:Name="TxtPhone2Label"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtPhone2Value"
                                           FontSize="12" HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <TextBlock x:Name="TxtAddressLabel"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtAddressValue"
                                           FontSize="12" HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI" MaxWidth="150"
                                           TextWrapping="Wrap" TextAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <TextBlock x:Name="TxtRepLabel"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtRepValue"
                                           FontSize="12" HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>

                            <!-- Notes -->
                            <Border x:Name="NotesRow" Visibility="Collapsed"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                                <TextBlock x:Name="TxtNotesValue" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Mini Statement Section -->
                    <Border Padding="16,14">
                        <StackPanel>
                            <TextBlock x:Name="TxtStatementTitle"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,10"
/>

                            <!-- Transaction rows (built in code) -->
                            <StackPanel x:Name="TransactionsPanel"/>

                            <!-- View full statement button -->
                            <Button x:Name="BtnFullStatement"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Height="34" Margin="0,10,0,0"
                                    Click="BtnFullStatement_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtBtnFullStatement" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Quick Actions ── -->
            <Border Grid.Row="2" Padding="12,10"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <!-- Row 1 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnNewInvoice"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="36" FontSize="12" Padding="0"
                                Click="BtnNewInvoice_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnNewInvoice" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" x:Name="BtnReceipt"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="36" FontSize="12" Padding="0"
                                Click="BtnReceipt_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnReceipt" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <!-- Row 2 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnEdit"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="34" FontSize="12" Padding="0"
                                Click="BtnEdit_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnEdit" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" x:Name="BtnToggleStatus"
                                Style="{StaticResource DangerButtonStyle}"
                                Height="34" FontSize="12" Padding="0"
                                Click="BtnToggleStatus_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnToggleStatus" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
