<UserControl x:Class="ERPSystem.Controls.Customers.CustomerAccountStatementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{StaticResource AppBgBrush}">

    <UserControl.Resources>
        <Style x:Key="StmtFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="StmtActionBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="EmptyStatePanel" Visibility="Collapsed"
                Background="{StaticResource AppBgBrush}" Padding="32,48">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <Border Width="56" Height="56" CornerRadius="28"
                        Background="{StaticResource PrimaryVeryLightBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="يرجى اختيار عميل من القائمة لعرض كشف الحساب"
                           FontSize="15" FontWeight="SemiBold" TextAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Segoe UI, Tahoma, Arial" TextWrapping="Wrap"
                           Margin="0,0,0,8"/>
                <TextBlock Text="يمكنك فتح كشف الحساب من سجل العملاء أو من مركز عمليات العميل."
                           FontSize="12" TextAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI, Tahoma, Arial" TextWrapping="Wrap"
                           Margin="0,0,0,20"/>
                <Button x:Name="BtnOpenCustomerList" Content="فتح سجل العملاء"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="38" Padding="20,0" HorizontalAlignment="Center"
                        Click="BtnOpenCustomerList_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="StatementContent" VerticalScrollBarVisibility="Auto" Padding="16,12">
        <StackPanel MaxWidth="1400">
            <TextBlock x:Name="TxtTableTitle" Text="كشف حساب"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="Segoe UI, Tahoma, Arial" Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="بحث في الكشف" Style="{StaticResource StmtFieldLabel}"/>
                            <TextBox x:Name="TxtSearch" Height="36"
                                     Style="{StaticResource EnterpriseInputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="من تاريخ" Style="{StaticResource StmtFieldLabel}"/>
                            <DatePicker x:Name="DpFrom" Height="36"
                                        Style="{StaticResource EnterpriseDatePickerStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="إلى تاريخ" Style="{StaticResource StmtFieldLabel}"/>
                            <DatePicker x:Name="DpTo" Height="36"
                                        Style="{StaticResource EnterpriseDatePickerStyle}"/>
                        </StackPanel>
                    </Grid>

                    <WrapPanel>
                        <Button Style="{StaticResource StmtActionBtn}" Background="#10B981" Margin="0,0,8,0"
                                Click="BtnReceipt_Click" Content="سند قبض"/>
                        <Button x:Name="BtnReconcile" Style="{StaticResource StmtActionBtn}" Background="#DC2626" Margin="0,0,8,0"
                                Click="BtnReconcile_Click" Content="مطابقة الكشف"/>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnPrint_Click" Content="طباعة"/>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnPdf_Click" Content="PDF"/>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnExcel_Click" Content="Excel"/>
                    </WrapPanel>
                    <TextBlock Text="المطابقة الجديدة تحل محل السابقة — لا يوجد تراجع تلقائي."
                               FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <UniformGrid Columns="4" Rows="2">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="رصيد افتتاحي" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtOpeningBalance" Text="0.00 $" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="رصيد ختامي" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtClosingBalance" Text="0.00 $" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="رصيد المطابقة" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtReconciliationBalance" Text="—" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="تاريخ آخر مطابقة" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtReconciliationDate" Text="—" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <Border Style="{StaticResource CardNoPaddingStyle}">
                <DataGrid x:Name="LinesGrid"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource EnterpriseColumnHeaderStyle}"
                          RowStyle="{StaticResource EnterpriseDataGridRowStyle}"
                          CellStyle="{StaticResource EnterpriseDataGridCellStyle}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          SelectionMode="Single" MinHeight="320"
                          LoadingRow="LinesGrid_LoadingRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="نوع الحركة" Binding="{Binding MovementTypeDisplay}" Width="100"/>
                        <DataGridTextColumn Header="نوع البضاعة" Binding="{Binding FabricDescription}" Width="*" MinWidth="160"/>
                        <DataGridTextColumn Header="عدد الأثواب" Binding="{Binding RollCountDisplay}" Width="90"/>
                        <DataGridTextColumn Header="مجموع الأطوال" Binding="{Binding TotalMetersDisplay}" Width="110"/>
                        <DataGridTextColumn Header="السعر" Binding="{Binding UnitPriceDisplay}" Width="90"/>
                        <DataGridTextColumn Header="مجموع المبلغ" Binding="{Binding LineAmountDisplay}" Width="110"/>
                        <DataGridTemplateColumn Header="رقم المستند" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DocumentNumber}" Foreground="#DC2626"
                                               FontWeight="SemiBold" Cursor="Hand" TextDecorations="Underline"
                                               MouseLeftButtonUp="DocumentNumber_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding DateDisplay}" Width="100"/>
                        <DataGridTextColumn Header="ملاحظة" Binding="{Binding NotesDisplay}" Width="120"/>
                        <DataGridTextColumn Header="الرصيد المتراكم" Binding="{Binding RunningBalanceDisplay}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
