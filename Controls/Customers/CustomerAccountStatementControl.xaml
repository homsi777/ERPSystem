<UserControl x:Class="ERPSystem.Controls.Customers.CustomerAccountStatementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{StaticResource AppBgBrush}">

    <UserControl.Resources>
        <Style x:Key="StmtFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="StmtActionBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
        <StackPanel MaxWidth="1280">
            <TextBlock x:Name="TxtTableTitle" Text="كشف حساب"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="Segoe UI, Tahoma, Arial" Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="بحث في الكشف" Style="{StaticResource StmtFieldLabel}"/>
                            <TextBox x:Name="TxtSearch" Height="36" Padding="8,0"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="من تاريخ" Style="{StaticResource StmtFieldLabel}"/>
                            <DatePicker x:Name="DpFrom" Height="36"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="إلى تاريخ" Style="{StaticResource StmtFieldLabel}"/>
                            <DatePicker x:Name="DpTo" Height="36"/>
                        </StackPanel>
                    </Grid>

                    <WrapPanel>
                        <Button Style="{StaticResource StmtActionBtn}" Background="#10B981" Margin="0,0,8,0"
                                Click="BtnReceipt_Click" Content="سند قبض"/>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnPrint_Click" Content="طباعة"/>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnPdf_Click" Content="PDF"/>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnExcel_Click" Content="Excel"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <UniformGrid Columns="4">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="رصيد افتتاحي" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtOpeningBalance" Text="0.00 ر.س" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="إجمالي مدين" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtTotalDebit" Text="0.00 ر.س" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="إجمالي دائن" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtTotalCredit" Text="0.00 ر.س" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="رصيد ختامي" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="TxtClosingBalance" Text="0.00 ر.س" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <Border Style="{StaticResource CardNoPaddingStyle}">
                <DataGrid x:Name="LinesGrid"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource EnterpriseColumnHeaderStyle}"
                          RowStyle="{StaticResource EnterpriseDataGridRowStyle}"
                          CellStyle="{StaticResource EnterpriseDataGridCellStyle}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          MinHeight="240">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding DateDisplay}" Width="100"/>
                        <DataGridTextColumn Header="نوع المستند" Binding="{Binding DocumentTypeDisplay}" Width="120"/>
                        <DataGridTemplateColumn Header="رقم المستند" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DocumentNumber}" Foreground="#DC2626"
                                               FontWeight="SemiBold" Cursor="Hand" TextDecorations="Underline"
                                               MouseLeftButtonUp="DocumentNumber_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="مدين" Binding="{Binding DebitDisplay}" Width="100"/>
                        <DataGridTextColumn Header="دائن" Binding="{Binding CreditDisplay}" Width="100"/>
                        <DataGridTextColumn Header="الرصيد" Binding="{Binding BalanceDisplay}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
