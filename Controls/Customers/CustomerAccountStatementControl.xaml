<UserControl x:Class="ERPSystem.Controls.Customers.CustomerAccountStatementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ERPSystem.Controls.Customers"
             FlowDirection="RightToLeft"
             Background="{StaticResource AppBgBrush}">

    <UserControl.Resources>
        <Style x:Key="StmtFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="StmtActionBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SummaryMetricCell" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="SummaryMetricHighlight" TargetType="Border" BasedOn="{StaticResource SummaryMetricCell}">
            <Setter Property="Background" Value="#FEF9C3"/>
            <Setter Property="BorderBrush" Value="#FDE047"/>
        </Style>

        <Style x:Key="StmtTableHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F766E"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,10"/>
        </Style>

        <DataTemplate DataType="{x:Type local:StatementDivider}">
            <Border Margin="0,4,0,4" Height="2">
                <Line X1="0" Y1="1" X2="2000" Y2="1"
                      Stroke="#CBD5E1" StrokeThickness="2"
                      StrokeDashArray="6,4"/>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:StatementLineRow}">
            <Border x:Name="RowRoot" Background="White" Padding="0,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding GoodsSummary}" FontSize="12"
                               Padding="10,10" VerticalAlignment="Center"
                               FontFamily="Segoe UI, Tahoma, Arial"/>
                    <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontSize="12"
                               Padding="10,10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding Lengths}" FontSize="12"
                               Padding="10,10" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="{Binding AvgPrice, StringFormat=N1}" FontSize="12"
                               Padding="10,10" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="{Binding InvoiceTotal, StringFormat='$#,##0'}" FontSize="12"
                               FontWeight="SemiBold" Padding="10,10" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReturn}" Value="True">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="5" Text="{Binding InvoiceNumber}" FontSize="12"
                               Foreground="#DC2626" FontWeight="SemiBold"
                               Padding="10,10" VerticalAlignment="Center" Cursor="Hand"
                               TextDecorations="Underline"
                               Tag="{Binding InvoiceNumber}"
                               MouseLeftButtonUp="InvoiceNumber_Click"/>
                    <TextBlock Grid.Column="6" Text="{Binding Date}" FontSize="12"
                               Padding="10,10" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="7" Text="{Binding Notes}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Padding="10,10" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsReturn}" Value="True">
                    <Setter TargetName="RowRoot" Property="Background" Value="#FFEDD5"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
        <StackPanel MaxWidth="1280">

            <!-- Header -->
            <Grid Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="كشف حساب" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial"/>
                    <TextBlock Text="كشف حساب — فاتورة لكل سطر، تفصيل وملخص مالي"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Filters + actions -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="اختيار العميل" Style="{StaticResource StmtFieldLabel}"/>
                            <ComboBox x:Name="CmbCustomer" Height="36"
                                      Style="{StaticResource EnterpriseComboBoxStyle}" SelectedIndex="0">
                                <ComboBoxItem Content="محل الأناقة — CUS-001"/>
                                <ComboBoxItem Content="مؤسسة النسيج — CUS-002"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="تاريخ المطالبة" Style="{StaticResource StmtFieldLabel}"/>
                            <DatePicker x:Name="DpClaimDate" SelectedDate="2026-06-17" Height="36"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="من تاريخ" Style="{StaticResource StmtFieldLabel}"/>
                            <DatePicker x:Name="DpFrom" SelectedDate="2026-01-01" Height="36"/>
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="إلى تاريخ" Style="{StaticResource StmtFieldLabel}"/>
                            <DatePicker x:Name="DpTo" SelectedDate="2026-06-17" Height="36"/>
                        </StackPanel>
                    </Grid>

                    <WrapPanel>
                        <Button Style="{StaticResource StmtActionBtn}" Background="#EF4444" Margin="0,0,8,0"
                                Click="BtnReturn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="سند مرتجع" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource StmtActionBtn}" Background="#10B981" Margin="0,0,8,0"
                                Click="BtnReceipt_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="سند قبض" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource StmtActionBtn}" Background="#8B5CF6" Margin="0,0,8,0"
                                Click="BtnServices_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="خدمات" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnPrint_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Margin="0,0,6,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="طباعة كشف الحساب" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnPdf_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PDF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource StmtActionBtn}" Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,8,0" Click="BtnExcel_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Excel" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource StmtActionBtn}" Background="#F59E0B"
                                Click="BtnReconcile_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="مطابقة الكشف" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Customer info bar -->
            <Border Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <WrapPanel Grid.Column="0">
                        <TextBlock FontSize="12" FontFamily="Segoe UI, Tahoma, Arial" Margin="0,0,20,0">
                            <Run Text="الهاتف: " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="0333 111 222" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="12" FontFamily="Segoe UI, Tahoma, Arial" Margin="0,0,20,0">
                            <Run Text="المدينة: " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="دمشق" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="12" FontFamily="Segoe UI, Tahoma, Arial" Margin="0,0,20,0">
                            <Run Text="العنوان: " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="المزة — شارع الجلاء" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="12" FontFamily="Segoe UI, Tahoma, Arial">
                            <Run Text="الحد الائتماني: " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="$10,000" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </WrapPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Left">
                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="Segoe UI, Tahoma, Arial" HorizontalAlignment="Left">
                            <Run Text="آخر معاملة: "/><Run Text="2026-06-14"/>
                        </TextBlock>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#DC2626"
                                   FontFamily="Segoe UI, Tahoma, Arial" HorizontalAlignment="Left" Margin="0,2,0,0">
                            <Run Text="رصيد المعاملة: "/><Run Text="$3,200"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Financial summary -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="الملخص المالي" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,10"/>
                    <UniformGrid Columns="5">
                        <Border Style="{StaticResource SummaryMetricCell}">
                            <StackPanel>
                                <TextBlock Text="رصيد افتتاحي" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="$361,670-" FontSize="14" FontWeight="SemiBold" Foreground="#DC2626" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricCell}">
                            <StackPanel>
                                <TextBlock Text="مجموع المديونية" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="$403,220" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricCell}">
                            <StackPanel>
                                <TextBlock Text="مجموع الحسم" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="$17,800" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricCell}">
                            <StackPanel>
                                <TextBlock Text="مجموع الدفع" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="$1,450" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricHighlight}">
                            <StackPanel>
                                <TextBlock Text="الذمم المستحقة" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="$1,200" FontSize="14" FontWeight="SemiBold" Foreground="#DC2626" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricHighlight}">
                            <StackPanel>
                                <TextBlock Text="رصيد ختامي" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="$3,200" FontSize="14" FontWeight="SemiBold" Foreground="#DC2626" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricCell}">
                            <StackPanel>
                                <TextBlock Text="عدد الفواتير" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="12" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricCell}">
                            <StackPanel>
                                <TextBlock Text="مجموع الأثواب" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="80" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricCell}">
                            <StackPanel>
                                <TextBlock Text="مجموع الأطوال" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="32,300" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryMetricCell}">
                            <StackPanel>
                                <TextBlock Text="إجمالي المبالغ" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="$403,220" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Statement table -->
            <Border Style="{StaticResource CardNoPaddingStyle}">
                <StackPanel>
                    <TextBlock x:Name="TxtTableTitle" Text="كشف حساب — محل الأناقة"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Margin="12,10,12,8"/>
                    <Border Background="#F0FDFA" BorderBrush="#CCFBF1" BorderThickness="0,1,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ملخص البضاعة" Style="{StaticResource StmtTableHeader}"/>
                            <TextBlock Grid.Column="1" Text="عدد" Style="{StaticResource StmtTableHeader}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="الأطوال" Style="{StaticResource StmtTableHeader}"/>
                            <TextBlock Grid.Column="3" Text="متوسط السعر" Style="{StaticResource StmtTableHeader}"/>
                            <TextBlock Grid.Column="4" Text="إجمالي الفاتورة" Style="{StaticResource StmtTableHeader}"/>
                            <TextBlock Grid.Column="5" Text="رقم الفاتورة" Style="{StaticResource StmtTableHeader}"/>
                            <TextBlock Grid.Column="6" Text="التاريخ" Style="{StaticResource StmtTableHeader}"/>
                            <TextBlock Grid.Column="7" Text="الملاحظات" Style="{StaticResource StmtTableHeader}"/>
                        </Grid>
                    </Border>
                    <ItemsControl x:Name="LinesList"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
