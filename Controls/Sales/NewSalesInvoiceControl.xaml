<UserControl x:Class="ERPSystem.Controls.Sales.NewSalesInvoiceControl"
             x:Name="InvoiceRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="{StaticResource AppBgBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="InvoiceApproveBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FB7185" Offset="0"/>
                                    <GradientStop Color="#F43F5E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvoiceSaveDraftBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#78350F"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Background="#FFEDD5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FED7AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvoiceFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InvoiceSegmentBtn" TargetType="RadioButton">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="GroupName" Value="InvoicePaymentType"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvoiceItemsHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0FDFA"/>
            <Setter Property="Foreground" Value="#0F766E"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderBrush" Value="#CCFBF1"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
        </Style>
        <Style x:Key="InvoiceHeaderCell" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style x:Key="InvoiceGridCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="InvoiceGridEditText" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource InputTextBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontFamily" Value="Segoe UI, Tahoma, Arial"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
        <StackPanel MaxWidth="1200">

            <!-- Page header + actions -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="فاتورة بيع جديدة" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial"/>
                    <TextBlock Text="إنشاء فاتورة بيع — اختيار العميل، الحاوية، الأصناف، وعدد الأثواب (بدون أطوال)"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial" Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButtonStyle}" Margin="0,0,6,0"
                            Click="BtnPrint_Click" ToolTip="طباعة">
                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                    <Button Style="{StaticResource GhostButtonStyle}" Margin="0,0,6,0"
                            Click="BtnPdf_Click" ToolTip="PDF">
                        <TextBlock Text="PDF" FontSize="11" FontWeight="SemiBold"/>
                    </Button>
                    <Button Style="{StaticResource GhostButtonStyle}" Margin="0,0,6,0"
                            Click="BtnPreview_Click" ToolTip="معاينة">
                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                            Click="BtnCancel_Click" Content="إلغاء"/>
                    <Button Style="{StaticResource InvoiceSaveDraftBtn}" Margin="0,0,8,0"
                            Content="حفظ مسودة" Click="BtnSaveDraft_Click"/>
                    <Button Style="{StaticResource InvoiceApproveBtn}" Content="اعتماد الفاتورة"
                            Click="BtnApprove_Click"/>
                </StackPanel>
            </Grid>

            <!-- Workflow path -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="مسار فاتورة البيع" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="المحاسب ينشئ المسودة ← المستودع ينفّذ الأطوال ← المحاسب يعتمد ← التسليم"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial" Margin="0,0,0,12"/>
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="{StaticResource PrimaryBrush}" Margin="0,0,0,6">
                                <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="محاسب — مسودة" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontFamily="Segoe UI, Tahoma, Arial" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Column="1" Height="2" VerticalAlignment="Top" Margin="0,15,0,0"
                                Background="{StaticResource BorderBrush}"/>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Opacity="0.65">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="2" Margin="0,0,0,6">
                                <TextBlock Text="2" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="مستودع — تنفيذ" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI, Tahoma, Arial" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Column="3" Height="2" VerticalAlignment="Top" Margin="0,15,0,0"
                                Background="{StaticResource BorderBrush}"/>
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center" Opacity="0.65">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="2" Margin="0,0,0,6">
                                <TextBlock Text="3" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="محاسب — اعتماد" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI, Tahoma, Arial" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Column="5" Height="2" VerticalAlignment="Top" Margin="0,15,0,0"
                                Background="{StaticResource BorderBrush}"/>
                        <StackPanel Grid.Column="6" HorizontalAlignment="Center" Opacity="0.45">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="2" Margin="0,0,0,6">
                                <TextBlock Text="4" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="تسليم — قريباً" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI, Tahoma, Arial" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Draft header fields -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="28" Height="28" CornerRadius="6"
                                Background="{StaticResource PrimaryVeryLightBrush}" Margin="0,0,8,0">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="مسودة" Style="{StaticResource SectionTitleTextStyle}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="100"
                                Padding="10,4" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtStatusBadge" Text="مسودة" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Header fields — single bar (8 columns) -->
                    <Border Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" MinWidth="88"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1*" MinWidth="96"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.15*" MinWidth="110"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1*" MinWidth="96"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.2*" MinWidth="120"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1*" MinWidth="96"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.05*" MinWidth="100"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="0.95*" MinWidth="88"/>
                            </Grid.ColumnDefinitions>

                            <!-- 1. تاريخ -->
                            <StackPanel Grid.Column="0" Style="{StaticResource InvoiceHeaderCell}">
                                <TextBlock Text="التاريخ" Style="{StaticResource InvoiceFieldLabel}"/>
                                <DatePicker x:Name="DpDate" SelectedDate="2024-05-17" Height="36"
                                            Style="{StaticResource EnterpriseDatePickerStyle}"/>
                            </StackPanel>

                            <!-- 2. رقم الفاتورة -->
                            <StackPanel Grid.Column="2" Style="{StaticResource InvoiceHeaderCell}">
                                <TextBlock Text="رقم الفاتورة" Style="{StaticResource InvoiceFieldLabel}"/>
                                <TextBox x:Name="TxtInvoiceNumber" Text="جديد" IsReadOnly="True"
                                         Style="{StaticResource EnterpriseInputStyle}" Height="36"
                                         Background="White"/>
                            </StackPanel>

                            <!-- 3. العميل -->
                            <StackPanel Grid.Column="4" Style="{StaticResource InvoiceHeaderCell}">
                                <TextBlock Text="العميل" Style="{StaticResource InvoiceFieldLabel}"/>
                                <ComboBox x:Name="CmbCustomer" Height="36"
                                          Style="{StaticResource EnterpriseComboBoxStyle}"
                                          DisplayMemberPath="Display" IsEditable="False"/>
                            </StackPanel>

                            <!-- 4. المستودع -->
                            <StackPanel Grid.Column="6" Style="{StaticResource InvoiceHeaderCell}">
                                <TextBlock Text="المستودع" Style="{StaticResource InvoiceFieldLabel}"/>
                                <ComboBox x:Name="CmbWarehouse" Height="36"
                                          Style="{StaticResource EnterpriseComboBoxStyle}"
                                          DisplayMemberPath="Display" IsEditable="False"/>
                            </StackPanel>

                            <!-- 5. الحاوية -->
                            <StackPanel Grid.Column="8" Style="{StaticResource InvoiceHeaderCell}">
                                <TextBlock Text="الحاوية" Style="{StaticResource InvoiceFieldLabel}"/>
                                <ComboBox x:Name="CmbContainer" Height="36"
                                          Style="{StaticResource EnterpriseComboBoxStyle}"
                                          DisplayMemberPath="Display" IsEditable="False"/>
                            </StackPanel>

                            <!-- 6. الصندوق -->
                            <StackPanel Grid.Column="10" Style="{StaticResource InvoiceHeaderCell}">
                                <TextBlock Text="الصندوق" Style="{StaticResource InvoiceFieldLabel}"/>
                                <ComboBox x:Name="CmbCashbox" Height="36"
                                          Style="{StaticResource EnterpriseComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="الخزينة العامة"/>
                                    <ComboBoxItem Content="صندوق جدة"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- 7. نوع الدفع -->
                            <StackPanel Grid.Column="12" Style="{StaticResource InvoiceHeaderCell}">
                                <TextBlock Text="نوع الدفع" Style="{StaticResource InvoiceFieldLabel}"/>
                                <Border Background="White" CornerRadius="8" Padding="3" Height="36"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="BtnCash" Style="{StaticResource InvoiceSegmentBtn}"
                                                     Content="نقدي" IsChecked="True" Checked="BtnCash_Checked"/>
                                        <RadioButton x:Name="BtnCredit" Style="{StaticResource InvoiceSegmentBtn}"
                                                     Content="آجل"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 8. العملة -->
                            <StackPanel Grid.Column="14" Style="{StaticResource InvoiceHeaderCell}">
                                <TextBlock Text="العملة" Style="{StaticResource InvoiceFieldLabel}"/>
                                <ComboBox x:Name="CmbCurrency" Height="36"
                                          Style="{StaticResource EnterpriseComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="USD ($)"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- دفعة جزئية عند الآجل -->
                    <Border Margin="0,0,0,8" Padding="12,8"
                            Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                            CornerRadius="8"
                            Visibility="{Binding IsChecked, ElementName=BtnCredit, Converter={StaticResource BoolVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="دفعة من الفاتورة (آجل)"
                                       VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#92400E" FontFamily="Segoe UI, Tahoma, Arial"/>
                            <TextBox Grid.Column="2" x:Name="TxtPartialPayment"
                                     Style="{StaticResource EnterpriseInputStyle}"
                                     Height="34" VerticalContentAlignment="Center" Text="0"/>
                        </Grid>
                    </Border>

                    <StackPanel>
                        <TextBlock Text="ملاحظات" Style="{StaticResource InvoiceFieldLabel}"/>
                        <TextBox Style="{StaticResource EnterpriseInputStyle}" Height="36"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Items table -->
            <Border Style="{StaticResource CardNoPaddingStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="12,10,12,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="أصناف الفاتورة" Style="{StaticResource SectionTitleTextStyle}"
                                   VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <Button Grid.Row="1" HorizontalAlignment="Left" Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnAddLine_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="إضافة صنف" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Border Grid.Row="1" x:Name="SalePriceWarningBanner" Visibility="Collapsed"
                            Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                            CornerRadius="8" Padding="12,8" Margin="12,0,12,8">
                        <TextBlock Text="سعر البيع غير محدد لهذا التوب — يرجى إدخاله يدوياً"
                                   FontSize="12" Foreground="#92400E" FontWeight="SemiBold"
                                   FontFamily="Segoe UI, Tahoma, Arial"/>
                    </Border>
                    <DataGrid Grid.Row="2" x:Name="ItemsGrid"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderLightBrush}"
                              BorderThickness="0" Background="White"
                              RowHeight="44" FontSize="12"
                              FontFamily="Segoe UI, Tahoma, Arial"
                              ColumnHeaderStyle="{StaticResource InvoiceItemsHeader}"
                              CellEditEnding="ItemsGrid_CellEditEnding"
                              BeginningEdit="ItemsGrid_BeginningEdit"
                              PreparingCellForEdit="ItemsGrid_PreparingCellForEdit">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="اختيار من المخزون"
                                                    Width="240"
                                                    ItemsSource="{Binding StockOptions, ElementName=InvoiceRoot}"
                                                    SelectedItemBinding="{Binding SelectedStock, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    DisplayMemberPath="Display"/>
                            <DataGridTextColumn Header="نوع البضاعة" Binding="{Binding GoodsType}" Width="*"
                                                IsReadOnly="True"
                                                ElementStyle="{StaticResource InvoiceGridCellText}"/>
                            <DataGridTextColumn Header="كود الثوب" Binding="{Binding BoltCode}" Width="90"
                                                IsReadOnly="True"
                                                ElementStyle="{StaticResource InvoiceGridCellText}"/>
                            <DataGridTextColumn Header="اللون" Binding="{Binding Color}" Width="80"
                                                IsReadOnly="True"
                                                ElementStyle="{StaticResource InvoiceGridCellText}"/>
                            <DataGridTextColumn Header="عدد الأثواب" Binding="{Binding RollCountText, UpdateSourceTrigger=PropertyChanged}" Width="90"
                                                ElementStyle="{StaticResource InvoiceGridCellText}"
                                                EditingElementStyle="{StaticResource InvoiceGridEditText}"/>
                            <DataGridTemplateColumn Header="الأطوال" Width="130" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFEDD5" CornerRadius="100"
                                                Padding="8,3" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding LengthStatus}" FontSize="10"
                                                       Foreground="#C2410C" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="الوحدة" Binding="{Binding Unit}" Width="70"
                                                IsReadOnly="True"
                                                ElementStyle="{StaticResource InvoiceGridCellText}"/>
                            <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged}" Width="90"
                                                ElementStyle="{StaticResource InvoiceGridCellText}"
                                                EditingElementStyle="{StaticResource InvoiceGridEditText}"/>
                            <DataGridTemplateColumn Header="إجراءات" Width="60" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                Style="{StaticResource GhostButtonStyle}" FontSize="12"
                                                Tag="{Binding}" Click="BtnRemoveLine_Click"
                                                ToolTip="حذف"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Summary -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="ملخص الأثواب" Style="{StaticResource SectionTitleTextStyle}"/>
                    <WrapPanel x:Name="SummaryPills" Margin="0,4,0,8"/>
                    <TextBlock Text="لا يمكن حساب المبلغ قبل أن يُدخل أمين المستودع طول كل ثوب على حدة"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI, Tahoma, Arial" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
