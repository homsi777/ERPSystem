<UserControl x:Class="ERPSystem.Controls.Sales.InvoiceDetailsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1,0,0,0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Invoice header -->
                <RowDefinition Height="*"/>       <!-- Scrollable body -->
                <RowDefinition Height="Auto"/>   <!-- Quick actions -->
            </Grid.RowDefinitions>

            <!-- ══ INVOICE HEADER ══ -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="16,14">
                <StackPanel>
                    <!-- Invoice number + date -->
                    <Grid Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="TxtInvoiceNum"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtInvoiceDate"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- Status badge top right -->
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Border x:Name="BadgeDocStatus" CornerRadius="5" Padding="8,3" Margin="0,0,0,5">
                                <TextBlock x:Name="TxtDocStatus" FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <Border x:Name="BadgePayStatus" CornerRadius="5" Padding="8,3" HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtPayStatus" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Meta: type · method · user · branch -->
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="BadgeType" CornerRadius="4" Padding="6,2" Margin="0,0,5,0">
                            <TextBlock x:Name="TxtType" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <Border x:Name="BadgeMethod" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="6,2" Margin="0,0,5,0">
                            <TextBlock x:Name="TxtPayMethod" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="6,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtUser" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ SCROLLABLE BODY ══ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Customer Block -->
                    <Border Padding="16,12" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock x:Name="TxtCustomerSectionTitle"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,8"/>

                            <!-- Customer name + over-limit -->
                            <Grid Margin="0,0,0,4">
                                <TextBlock x:Name="TxtCustomerName"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI, Tahoma, Arial"/>
                                <Border x:Name="BadgeOverLimit" CornerRadius="4" Padding="6,2"
                                        Background="{StaticResource DangerBgBrush}"
                                        HorizontalAlignment="Right" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                   Foreground="{StaticResource DangerBrush}" Margin="0,0,3,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtOverLimit" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource DangerBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,3">
                                <TextBlock x:Name="TxtCustPhone" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <TextBlock x:Name="TxtCustTypeLabel" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtCustTypeVal" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Right" FontFamily="Segoe UI"/>
                            </Grid>
                            <Grid>
                                <TextBlock x:Name="TxtCustBalLabel" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtCustBalVal" FontSize="11"
                                           HorizontalAlignment="Right" FontFamily="Segoe UI"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Financial Block -->
                    <Border Padding="16,12" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock x:Name="TxtFinancialTitle"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,4">
                                <TextBlock x:Name="TxtSubtotalLabel" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtSubtotalVal" FontSize="12"
                                           HorizontalAlignment="Right" Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                            <Grid x:Name="DiscountRow" Margin="0,0,0,4">
                                <TextBlock x:Name="TxtDiscountLabel" FontSize="12"
                                           Foreground="{StaticResource SuccessBrush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtDiscountVal" FontSize="12"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource SuccessBrush}" FontFamily="Segoe UI"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock x:Name="TxtTaxLabel" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtTaxVal" FontSize="12"
                                           HorizontalAlignment="Right" Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>

                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                            <!-- Grand total (prominent) -->
                            <Border x:Name="GrandTotalBorder" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                                <Grid>
                                    <TextBlock x:Name="TxtGrandLabel" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="TxtGrandVal" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource PrimaryBrush}" FontFamily="Segoe UI"/>
                                </Grid>
                            </Border>

                            <!-- Paid / Remaining -->
                            <Grid Margin="0,0,0,4">
                                <TextBlock x:Name="TxtPaidLabel" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtPaidVal" FontSize="12"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource SuccessBrush}" FontFamily="Segoe UI"
                                           FontWeight="SemiBold"/>
                            </Grid>
                            <Grid>
                                <TextBlock x:Name="TxtRemainingLabel" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtRemainingVal" FontSize="13"
                                           HorizontalAlignment="Right" FontFamily="Segoe UI"
                                           FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Mini Line Items -->
                    <Border Padding="16,12">
                        <StackPanel>
                            <TextBlock x:Name="TxtLinesSectionTitle"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI" Margin="0,0,0,8"/>

                            <StackPanel x:Name="LinesPanel"/>

                            <Button x:Name="BtnViewAllLines"
                                    Style="{StaticResource GhostButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Height="32" Margin="0,8,0,0"
                                    Click="BtnViewAllLines_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A4;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtBtnViewLines" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <!-- Extension point placeholders -->
                            <Border x:Name="LinkedDocsPanel" Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <!-- TODO: attach receipt voucher link -->
                                <!-- TODO: attach journal entry link  -->
                                <!-- TODO: attach stock movement link -->
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ══ QUICK ACTIONS ══ -->
            <Border Grid.Row="2" Padding="12,10"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <!-- Row 1: Print + Edit -->
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnPrint"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="34" FontSize="12" Padding="0"
                                Click="BtnPrint_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnPrint" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" x:Name="BtnEdit"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="34" FontSize="12" Padding="0"
                                Click="BtnEdit_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnEdit" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <!-- Row 2: Return + Receipt -->
                    <Grid Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnReturn"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="34" FontSize="12" Padding="0"
                                Click="BtnReturn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnReturn" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" x:Name="BtnReceipt"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="34" FontSize="12" Padding="0"
                                Click="BtnReceipt_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnReceipt" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <!-- Row 3: Open Customer + Cancel -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnOpenCustomer"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="32" FontSize="11" Padding="0"
                                Click="BtnOpenCustomer_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnOpenCustomer" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" x:Name="BtnCancel"
                                Style="{StaticResource DangerButtonStyle}"
                                Height="32" FontSize="11" Padding="0"
                                Click="BtnCancel_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnCancel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
