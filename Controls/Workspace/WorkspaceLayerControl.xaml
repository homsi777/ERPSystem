<UserControl x:Class="ERPSystem.Controls.Workspace.WorkspaceLayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:workspace="clr-namespace:ERPSystem.Core.Workspace"
             FlowDirection="RightToLeft"
             Visibility="Collapsed"
             x:Name="Root">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- Dimmed backdrop — module remains visible behind -->
        <Border Background="#660F172A" MouseDown="Backdrop_MouseDown"/>

        <!-- Workspace panel (slides over module) -->
        <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Margin="80,12,12,12"
                Background="{StaticResource AppBgBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Effect="{StaticResource ElevatedShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Tab bar -->
                    <RowDefinition Height="*"/>
                    <!-- Content -->
                </Grid.RowDefinitions>

                <!-- Tab bar + close all -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TabItems">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type workspace:WorkspaceInstance}">
                                        <Button Click="Tab_Click" Tag="{Binding}"
                                                Margin="0,0,6,0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Padding" Value="12,6"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryVeryLightBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontSize="12"
                                                           FontFamily="Segoe UI, Tahoma, Arial"
                                                           MaxWidth="200" TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                        Width="20" Height="20" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Click="CloseTab_Click" Tag="{Binding}"
                                                        ToolTip="إغلاق"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{StaticResource GhostButtonStyle}" Height="30" Padding="10,0"
                                    Click="CloseAll_Click" FontSize="12">
                                <TextBlock Text="إغلاق الكل" FontFamily="Segoe UI, Tahoma, Arial"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Active workspace content -->
                <Border Grid.Row="1" Background="{StaticResource AppBgBrush}"
                        CornerRadius="0,0,12,12">
                    <ContentControl x:Name="ActiveContentHost"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
