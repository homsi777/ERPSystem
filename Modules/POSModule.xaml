<UserControl x:Class="ERPSystem.Modules.POSModule"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════
         ROOT GRID — Session bar + Main content
    ════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <!-- SESSION BAR -->
            <RowDefinition Height="*"/>
            <!-- MAIN CONTENT -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             ROW 0 — SESSION BAR (dark toolbar)
        ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0F172A">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Session info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="8" Height="8" CornerRadius="4" Background="#4ADE80" Margin="0,0,8,0"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtSessionNumber" Text="POS-0042"
                                       FontSize="13" FontWeight="Bold" Foreground="White"
                                       FontFamily="Segoe UI, Tahoma, Arial"/>
                            <Border Background="#1E293B" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                <TextBlock x:Name="TxtSessionTerminal" Text="T-01"
                                           FontSize="10" Foreground="#94A3B8"
                                           FontFamily="Segoe UI"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtCashierName" Text="أحمد محمد"
                                       FontSize="11" Foreground="#94A3B8" FontFamily="Segoe UI"/>
                            <TextBlock Text=" • " FontSize="11" Foreground="#475569"/>
                            <TextBlock x:Name="TxtSessionElapsed" Text="00:00"
                                       FontSize="11" Foreground="#64748B" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="1" Width="1" Background="#1E293B" Margin="0,10"/>

                <!-- Session stats -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock x:Name="TxtStatOrders" Text="0"
                                   FontSize="15" FontWeight="Bold" Foreground="White"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatOrdersLabel" Text="طلب"
                                   FontSize="10" Foreground="#64748B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock x:Name="TxtStatSales" Text="0.00 ر.س"
                                   FontSize="15" FontWeight="Bold" Foreground="#4ADE80"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatSalesLabel" Text="مبيعات اليوم"
                                   FontSize="10" Foreground="#64748B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Center barcode search -->
                <Border Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#1E293B" BorderBrush="#334155" BorderThickness="1"
                        CornerRadius="8" Width="320" Height="34">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="#64748B"
                                   VerticalAlignment="Center" Margin="10,0,8,0"/>
                        <TextBox Grid.Column="1" x:Name="TxtBarcodeSearch"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="13" FontFamily="Segoe UI"
                                 Foreground="White" CaretBrush="White"
                                 VerticalAlignment="Center"
                                 TextChanged="TxtBarcodeSearch_TextChanged"
                                 KeyDown="TxtBarcodeSearch_KeyDown"/>
                        <TextBlock Grid.Column="2" x:Name="TxtBarcodeHint"
                                   FontSize="11" Foreground="#475569"
                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                   FontFamily="Segoe UI" IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- Right: session actions -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource POSSessionBtnStyle}"
                            x:Name="BtnNewOrder" Click="BtnNewOrder_Click" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtBtnNewOrder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource POSSessionBtnStyle}"
                            x:Name="BtnHeldOrders" Click="BtnHeldOrders_Click" Margin="0,0,6,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Margin="12,0">
                                <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnHeld" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="HeldBadge" Background="{StaticResource WarningBrush}"
                                    CornerRadius="8" Padding="4,1"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-4,-4,0" Visibility="Collapsed">
                                <TextBlock x:Name="TxtHeldCount" Text="0"
                                           FontSize="9" Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource POSSessionBtnStyle}"
                            x:Name="BtnCloseShift" Click="BtnCloseShift_Click"
                            BorderBrush="#DC2626" Foreground="#FCA5A5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtBtnCloseShift" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             ROW 1 — MAIN POS LAYOUT  (products | order panel)
        ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Products panel -->
                <ColumnDefinition Width="390"/>
                <!-- Order/cart panel -->
            </Grid.ColumnDefinitions>

            <!-- ════════════════════════════════════════
                 PRODUCTS PANEL
            ════════════════════════════════════════ -->
            <Grid Grid.Column="0" Background="{StaticResource AppBgBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <!-- Category tabs -->
                    <RowDefinition Height="*"/>
                    <!-- Product grid -->
                </Grid.RowDefinitions>

                <!-- Category Tabs bar -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="CategoriesPanel" Orientation="Horizontal"
                                    VerticalAlignment="Center"/>
                    </ScrollViewer>
                </Border>

                <!-- Product WrapPanel in scroll -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="6,6,6,0">
                    <StackPanel>
                        <WrapPanel x:Name="ProductsPanel" Orientation="Horizontal" Margin="2"/>
                        <Border x:Name="EmptyProductsState" Visibility="Collapsed"
                                Margin="24,48" HorizontalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtNoProducts"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,4"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtNoProductsSub"
                                           FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ════════════════════════════════════════
                 ORDER / CART PANEL
            ════════════════════════════════════════ -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Invoice header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Customer row -->
                        <RowDefinition Height="*"/>
                        <!-- Cart items -->
                        <RowDefinition Height="Auto"/>
                        <!-- Discount + notes -->
                        <RowDefinition Height="Auto"/>
                        <!-- Totals -->
                        <RowDefinition Height="Auto"/>
                        <!-- Payment methods -->
                        <RowDefinition Height="Auto"/>
                        <!-- Action buttons -->
                    </Grid.RowDefinitions>

                    <!-- Invoice header -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="TxtInvoiceNumber"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtInvoiceDate"
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="ItemCountBadge"
                                    Background="{StaticResource PrimaryBrush}"
                                    CornerRadius="10" Padding="8,3" Visibility="Collapsed"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="TxtItemCountBadge"
                                           FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Customer row -->
                    <Border Grid.Row="1" Padding="14,10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                    Background="{StaticResource PrimaryVeryLightBrush}"
                                    Margin="0,0,10,0">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtCustomerLabel"
                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtCustomerName"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <Button Grid.Column="2" x:Name="BtnChangeCustomer"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Height="28" Padding="8,0" FontSize="11"
                                    Click="BtnChangeCustomer_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Margin="0,0,4,0"/>
                                    <TextBlock x:Name="TxtBtnChangeCustomer"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Cart items area -->
                    <Grid Grid.Row="2">
                        <!-- Items list (built in code) -->
                        <ScrollViewer x:Name="CartScrollViewer" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CartItemsPanel"/>
                        </ScrollViewer>

                        <!-- Empty cart overlay -->
                        <Border x:Name="EmptyCartState" VerticalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center" Margin="24">
                                <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="44"
                                           Foreground="{StaticResource BorderBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtEmptyCartTitle"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,4"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtEmptyCartSub"
                                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Discount + Notes -->
                    <Border Grid.Row="3" x:Name="DiscountNotesPanel"
                            Padding="14,10" Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <!-- Discount row -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="56"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="TxtDiscountLabel"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <Border Grid.Column="2" Background="White"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="6,4">
                                    <TextBox x:Name="TxtDiscountValue" Text="0"
                                             Background="Transparent" BorderThickness="0"
                                             FontSize="13" FontFamily="Segoe UI"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             TextAlignment="Center"
                                             TextChanged="TxtDiscountValue_TextChanged"/>
                                </Border>
                                <Button Grid.Column="4" x:Name="BtnDiscountType"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Height="30" FontSize="12" Padding="0"
                                        Click="BtnDiscountType_Click">
                                    <TextBlock x:Name="TxtDiscountType" Text="ر.س"/>
                                </Button>
                            </Grid>
                            <!-- Notes row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="White"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="8,4">
                                    <TextBox x:Name="TxtOrderNotes" Background="Transparent"
                                             BorderThickness="0" FontSize="12" FontFamily="Segoe UI"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             MaxLength="120"/>
                                </Border>
                                <Border Grid.Column="2" Background="White"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="8,4">
                                    <TextBox x:Name="TxtCouponCode" Background="Transparent"
                                             BorderThickness="0" FontSize="12" FontFamily="Segoe UI"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             MaxLength="20"
                                             KeyDown="TxtCouponCode_KeyDown"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Totals -->
                    <Border Grid.Row="4" Padding="14,12"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,5">
                                <TextBlock x:Name="TxtSubtotalLabel"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtSubtotalValue"
                                           FontSize="12" HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                            <Grid x:Name="DiscountTotalRow" Margin="0,0,0,5">
                                <TextBlock x:Name="TxtTotalDiscountLabel"
                                           FontSize="12" Foreground="{StaticResource SuccessBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtTotalDiscountValue"
                                           FontSize="12" HorizontalAlignment="Right"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <TextBlock x:Name="TxtTaxLabel"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtTaxValue"
                                           FontSize="12" HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,8"/>
                            <Grid>
                                <TextBlock x:Name="TxtGrandTotalLabel"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TxtGrandTotalValue"
                                           FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Payment methods -->
                    <Border Grid.Row="5" Padding="14,10"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="BtnPayCash"
                                    Style="{StaticResource POSPaymentActiveBtnStyle}"
                                    Click="PaymentMethod_Click" Tag="Cash">
                                <StackPanel>
                                    <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtPayCash" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" x:Name="BtnPayCard"
                                    Style="{StaticResource POSPaymentBtnStyle}"
                                    Click="PaymentMethod_Click" Tag="Card">
                                <StackPanel>
                                    <TextBlock Text="&#xE8CE;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtPayCard" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="4" x:Name="BtnPayTransfer"
                                    Style="{StaticResource POSPaymentBtnStyle}"
                                    Click="PaymentMethod_Click" Tag="Transfer">
                                <StackPanel>
                                    <TextBlock Text="&#xE909;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtPayTransfer" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="6" x:Name="BtnPaySplit"
                                    Style="{StaticResource POSPaymentBtnStyle}"
                                    Click="PaymentMethod_Click" Tag="Split">
                                <StackPanel>
                                    <TextBlock Text="&#xE8D5;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtPaySplit" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="6" Margin="14">
                        <!-- CHECKOUT -->
                        <Button x:Name="BtnCheckout" Style="{StaticResource POSCheckoutStyle}"
                                IsEnabled="False" Click="BtnCheckout_Click" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtBtnCheckout"
                                           VerticalAlignment="Center" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Button>
                        <!-- Secondary row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="BtnHoldOrder"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="36" Padding="0" FontSize="12"
                                    Click="BtnHoldOrder_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtBtnHold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" x:Name="BtnPrintReceipt"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="36" Padding="0" FontSize="12"
                                    Click="BtnPrintReceipt_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtBtnPrint" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="4" x:Name="BtnClearCart"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Height="36" Padding="0" FontSize="12"
                                    Click="BtnClearCart_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtBtnClear" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
